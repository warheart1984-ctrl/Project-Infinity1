FROM python:3.12-slim

WORKDIR /app
COPY . /app

RUN pip install --no-cache-dir fastapi uvicorn pydantic httpx a2wsgi 2>/dev/null || \
    pip install --no-cache-dir fastapi uvicorn pydantic httpx

ENV PYTHONPATH=/app
ENV AAIS_RUNTIME_DIR=/app/.runtime/aais-data
EXPOSE 8000

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
