# Appwrite — optional governance projection (never replaces JSONL ledger authority)
# Copy values into project root .env or export before enabling AAIS_APPWRITE_SINK=1
# See deploy/appwrite/README.md for table creation steps.

AAIS_APPWRITE_SINK=0

APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-server-api-key
APPWRITE_DATABASE_ID=governance

# Optional overrides (defaults shown)
APPWRITE_GOVERNANCE_TABLE_ID=governance_contracts
APPWRITE_LEDGER_TABLE_ID=ledger_events
