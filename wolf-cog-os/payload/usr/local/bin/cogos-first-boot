#!/bin/sh
# First boot from installed disk: reveal Wolf CoG OS + full daily driver + Nova stack.
set -eu

MARKER=/opt/cogos/memory/operator/FIRST_BOOT_PENDING
ALT_MARKER=/var/lib/cogos/memory/operator/FIRST_BOOT_PENDING
LOG=/var/log/cogos-first-boot.log

log() {
  printf '%s cogos-first-boot: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$*" | tee -a "$LOG"
}

if [ ! -f "$MARKER" ] && [ ! -f "$ALT_MARKER" ]; then
  exit 0
fi

log "=== Wolf CoG OS takeover — first boot from disk ==="

if [ -x /usr/local/bin/cogos-runtime-start ]; then
  /usr/local/bin/cogos-runtime-start >> "$LOG" 2>&1 || log "cogos-runtime-start deferred"
elif [ -x /etc/init.d/90cogos ]; then
  /etc/init.d/90cogos start >> "$LOG" 2>&1 || log "90cogos start deferred"
elif [ -x /usr/local/bin/cogos-daemon ]; then
  /usr/local/bin/cogos-daemon --daemon >> "$LOG" 2>&1 || log "cogos-daemon start deferred"
fi

if [ -x /usr/local/bin/cogos-reveal-identity ]; then
  /usr/local/bin/cogos-reveal-identity / >> "$LOG" 2>&1 || log "identity reveal partial"
fi

if [ -f /opt/cogos/config/boot_profile_daily_driver.json ]; then
  cp -f /opt/cogos/config/boot_profile_daily_driver.json /opt/cogos/config/boot_profile.json
  log "daily driver boot profile active (Nova enabled)"
fi

if [ -x /usr/local/bin/cogos-persist ]; then
  /usr/local/bin/cogos-persist bind >> "$LOG" 2>&1 || log "persist bind deferred"
fi

if command -v python3 >/dev/null 2>&1 && [ -f /opt/cogos/bin/cogos_first_run.py ]; then
  python3 /opt/cogos/bin/cogos_first_run.py apply \
    --hostname "$(cat /etc/hostname 2>/dev/null || echo cogos)" \
    --profile-id operator \
    --display-name Operator \
    --mode automatic \
    --workspace "Home Base" >> "$LOG" 2>&1 || log "first-run apply skipped"
fi

if [ -x /usr/local/bin/cogos-daily-driver ]; then
  /usr/local/bin/cogos-daily-driver enable >> "$LOG" 2>&1 || true
  /usr/local/bin/cogos-daily-driver boot >> "$LOG" 2>&1 || true
  /usr/local/bin/cogos-daily-driver daily >> "$LOG" 2>&1 || true
  /usr/local/bin/cogos-daily-driver pillars >> "$LOG" 2>&1 || true
  log "daily driver enabled"
fi

for nova_cmd in cogos-supernova cogos-nova-bridge cogos-nova-voice; do
  if [ -x "/usr/local/bin/$nova_cmd" ]; then
    "/usr/local/bin/$nova_cmd" status >> "$LOG" 2>&1 || true
  fi
done

if [ -x /usr/local/bin/cogos-desktop-start ]; then
  /usr/local/bin/cogos-desktop-start >> "$LOG" 2>&1 || true
fi

if [ -x /usr/local/bin/cogos-pid1-proof ]; then
  /usr/local/bin/cogos-pid1-proof >> "$LOG" 2>&1 || log "pid1 proof pending"
fi

if [ -x /usr/local/bin/cogos-doctor ]; then
  /usr/local/bin/cogos-doctor >> "$LOG" 2>&1 || true
fi

if [ -x /usr/local/bin/cogos-unified-verify ]; then
  /usr/local/bin/cogos-unified-verify >> "$LOG" 2>&1 || true
fi

rm -f "$MARKER" "$ALT_MARKER"
log "=== first boot complete — Wolf CoG OS daily driver online ==="
exit 0
