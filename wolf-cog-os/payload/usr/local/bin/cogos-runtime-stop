#!/bin/sh
# Native CoGOS runtime stop (systemd ExecStop).
set -eu

COGOS_LOG=/var/log/cogos-service.log
DAEMON_PID_FILE=/run/cogos-daemon.pid
DASHBOARD_PID_FILE=/run/cogos-dashboard.pid

log() {
  printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo boot)" "$*" >> "$COGOS_LOG" 2>/dev/null || true
}

if [ -x /usr/local/bin/cogos-stop-all ]; then
  /usr/local/bin/cogos-stop-all
  exit 0
fi

if [ -s "$DAEMON_PID_FILE" ]; then
  kill "$(cat "$DAEMON_PID_FILE")" 2>/dev/null || true
  rm -f "$DAEMON_PID_FILE"
  log "daemon stop requested"
fi
if [ -s "$DASHBOARD_PID_FILE" ]; then
  kill "$(cat "$DASHBOARD_PID_FILE")" 2>/dev/null || true
  rm -f "$DASHBOARD_PID_FILE"
  log "dashboard stop requested"
fi
exit 0
