#!/bin/sh
# Live session install launcher: direct cogos-install apply or reboot to gtk d-i.
set -eu

LOG=/var/log/cogos-launch-di-installer.log

log() {
  printf '%s cogos-launch-di-installer: %s\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$*" >>"$LOG"
}

if [ -z "${DISPLAY:-}" ] && [ -S /tmp/.X11-unix/X0 ]; then
  export DISPLAY=:0
fi

i=0
while [ "$i" -lt 30 ]; do
  [ -n "${DISPLAY:-}" ] && break
  i=$((i + 1))
  sleep 1
done

log "launch display=${DISPLAY:-unset} user=$(id -un 2>/dev/null || echo unknown)"

reboot_to_installer() {
  log "reboot requested"
  sync
  if command -v systemctl >/dev/null 2>&1; then
    exec systemctl reboot
  fi
  exec reboot
}

pick_install_disk() {
  lsblk -d -n -o NAME,SIZE,MODEL,TRAN 2>/dev/null \
    | awk '$1 !~ /^(loop|sr|ram)/ {print}' \
    | zenity --list --title="Install Wolf CoG OS" --width=520 --height=320 \
        --text="Select the whole disk to erase and install Wolf CoG OS.\nUSB/live boot disks are excluded when possible — verify carefully." \
        --column=Device --column=Size --column=Model --column=Bus \
    2>>"$LOG" || return 1
}

run_live_install() {
  line="$(pick_install_disk)" || return 1
  dev="$(printf '%s' "$line" | awk '{print $1}')"
  [ -n "$dev" ] || return 1
  target="/dev/$dev"
  log "live install selected target=$target"
  if ! command -v cogos-install >/dev/null 2>&1; then
    zenity --error --title="Install Wolf CoG OS" \
      --text="cogos-install not found in PATH." 2>>"$LOG" || true
    return 1
  fi
  if ! zenity --question --title="Confirm erase" --width=460 \
      --text="Install Wolf CoG OS to $target?\n\nThis ERASES the entire disk." \
      --ok-label="Install" --cancel-label="Cancel" 2>>"$LOG"; then
    return 0
  fi
  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec cogos-install apply --target "$target" --yes --confirm-erase "$dev" \
      >>"$LOG" 2>&1
  fi
  exec cogos-install apply --target "$target" --yes --confirm-erase "$dev" \
    >>"$LOG" 2>&1
}

if command -v zenity >/dev/null 2>&1; then
  choice="$(zenity --list --title="Install Wolf CoG OS" --width=480 --height=260 \
    --text="How do you want to install Wolf CoG OS?" \
    --column=Method --column=Description \
    "live" "Install from live session (recommended — WiFi works here)" \
    "reboot" "Reboot into gtk graphical installer" \
    2>>"$LOG")" || exit 0
  case "$choice" in
    live) run_live_install || exit 1 ;;
    reboot) reboot_to_installer ;;
    *) exit 0 ;;
  esac
  exit 0
fi

if command -v xmessage >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
  btn="$(xmessage -center -buttons "LiveInstall:10,RebootGtk:11,Cancel:12" \
    "Install Wolf CoG OS: live install or reboot to gtk installer?" 2>>"$LOG" || echo 12)"
  case "$btn" in
    10) run_live_install || exit 1 ;;
    11) reboot_to_installer ;;
    *) exit 0 ;;
  esac
  exit 0
fi

log "no display dialog tool; refusing silent action"
exit 1
