#!/bin/sh
# Post-install hook: enable CoGOS PID1 on target disk before first reboot.
# Called from Debian live-installer, d-i late_command, or cogos-install apply.
set -eu

TARGET=""
IN_TARGET=0
QUIET=0
KEEP_SYSTEMD_PID1=0
LOG=/var/log/cogos-install-finish.log

log() {
  [ "$QUIET" = "1" ] || printf '%s cogos-install-finish: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)" "$*" | tee -a "$LOG"
}

usage() {
  echo "Usage: cogos-install-finish --target /target [--quiet]"
  echo "       cogos-install-finish --in-target [--quiet]  (already inside installed system chroot)"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --target) TARGET="$2"; shift 2 ;;
    --in-target) IN_TARGET=1; TARGET="/"; shift ;;
    --keep-systemd-pid1) KEEP_SYSTEMD_PID1=1; shift ;;
    --quiet) QUIET=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) log "unknown arg: $1"; shift ;;
  esac
done

[ -n "$TARGET" ] || TARGET="/target"
[ -d "$TARGET/etc" ] || exit 0

if [ "$KEEP_SYSTEMD_PID1" = "0" ] && [ "${COGOS_KEEP_SYSTEMD_PID1:-0}" = "1" ]; then
  KEEP_SYSTEMD_PID1=1
fi

mkdir -p "$(dirname "$LOG")"
log "finalizing installed system (target=$TARGET in_target=$IN_TARGET keep_systemd_pid1=$KEEP_SYSTEMD_PID1)"

run_in_target() {
  if [ "$IN_TARGET" = "1" ]; then
    "$@"
  else
    chroot "$TARGET" "$@"
  fi
}

enable_target_unit() {
  unit="$1"
  wants_dir="$2"
  if [ ! -f "$TARGET/etc/systemd/system/$unit" ]; then
    return 1
  fi
  if run_in_target systemctl enable "$unit" >>"$LOG" 2>&1; then
    log "enabled $unit via systemctl"
    return 0
  fi
  mkdir -p "$TARGET/etc/systemd/system/$wants_dir"
  ln -sf "../$unit" "$TARGET/etc/systemd/system/$wants_dir/$unit"
  log "enabled $unit via symlink ($wants_dir fallback)"
  return 0
}

preserve_native_systemd_init() {
  if [ -x "$TARGET/usr/sbin/init.original" ]; then
    return 0
  fi
  local candidate resolved
  for candidate in \
    "$TARGET/lib/systemd/systemd" \
    "$TARGET/usr/lib/systemd/systemd"; do
    [ -e "$candidate" ] || continue
    if [ "$IN_TARGET" = "1" ]; then
      resolved="$(readlink -f "$candidate" 2>/dev/null || echo "$candidate")"
    else
      resolved="$(chroot "$TARGET" readlink -f "$candidate" 2>/dev/null || readlink -f "$candidate" 2>/dev/null || echo "$candidate")"
    fi
    if [ -x "$resolved" ]; then
      cp -a "$resolved" "$TARGET/usr/sbin/init.original"
      chmod +x "$TARGET/usr/sbin/init.original" 2>/dev/null || true
      log "preserved native systemd binary -> init.original ($resolved)"
      return 0
    fi
  done
  return 1
}

restore_systemd_pid1_links() {
  local candidate=""
  for candidate in \
    "$TARGET/lib/systemd/systemd" \
    "$TARGET/usr/lib/systemd/systemd"; do
    [ -x "$candidate" ] && break
    candidate=""
  done
  [ -n "$candidate" ] || return 1
  rm -f "$TARGET/usr/sbin/init" "$TARGET/sbin/init"
  ln -sf /lib/systemd/systemd "$TARGET/usr/sbin/init"
  if [ -d "$TARGET/sbin" ]; then
    ln -sf /lib/systemd/systemd "$TARGET/sbin/init"
  fi
  log "PID1 left on native systemd (/lib/systemd/systemd)"
  return 0
}

# --- PID1: d-i installs keep native systemd; metal/surprise may swap to cognitive_init ---
preserve_native_systemd_init || log "WARN: could not preserve init.original (PID1 swap may be skipped)"

if [ "$KEEP_SYSTEMD_PID1" = "1" ]; then
  restore_systemd_pid1_links || log "WARN: could not restore systemd PID1 links"
  log "d-i path: keeping native systemd PID1 (CoGOS runs via cogos-runtime.service)"
else
  cog_init="$TARGET/opt/cogos/bin/cognitive_init"
  if [ ! -x "$cog_init" ]; then
    log "WARN: cognitive_init missing on target — leaving stock init (Debian will boot)"
  elif [ ! -x "$TARGET/usr/sbin/init.original" ]; then
    log "WARN: init.original missing — refusing PID1 swap (prevents post-install stall)"
  else
    native=""
    if [ -L "$TARGET/usr/sbin/init" ] || [ -f "$TARGET/usr/sbin/init" ]; then
      if [ "$IN_TARGET" = "1" ]; then
        native="$(readlink -f /usr/sbin/init 2>/dev/null || true)"
      else
        native="$(chroot "$TARGET" readlink -f /usr/sbin/init 2>/dev/null || true)"
      fi
    fi
    if [ "$native" != "$cog_init" ] && [ "$native" != "/opt/cogos/bin/cognitive_init" ]; then
      rm -f "$TARGET/usr/sbin/init" "$TARGET/sbin/init"
      ln -sf /opt/cogos/bin/cognitive_init "$TARGET/usr/sbin/init"
      if [ -d "$TARGET/sbin" ]; then
        ln -sf /opt/cogos/bin/cognitive_init "$TARGET/sbin/init"
      fi
      log "enabled PID1: init -> cognitive_init on target disk"
      if run_in_target command -v update-initramfs >/dev/null 2>&1; then
        log "regenerating initramfs after PID1 swap"
        run_in_target update-initramfs -u -k all >>"$LOG" 2>&1 \
          || log "WARN: update-initramfs failed (boot may still work)"
      else
        log "WARN: update-initramfs not found — skipped"
      fi
    else
      log "PID1 already wired to cognitive_init"
    fi
  fi
fi
# --- Full daily-driver boot profile (Nova on) for first boot ---
if [ -f "$TARGET/opt/cogos/config/boot_profile_daily_driver.json" ]; then
  cp -f "$TARGET/opt/cogos/config/boot_profile_daily_driver.json" \
    "$TARGET/opt/cogos/config/boot_profile.json"
  log "boot profile set to daily_driver (Nova enabled)"
fi

# --- First-boot marker (identity reveal + stack bootstrap) ---
for dir in "$TARGET/opt/cogos/memory/operator" "$TARGET/var/lib/cogos/memory/operator"; do
  mkdir -p "$dir"
  date -u +%Y-%m-%dT%H:%M:%SZ > "$dir/FIRST_BOOT_PENDING"
done
if grep -q 'cogos\.calamares=1' /proc/cmdline 2>/dev/null \
   || [ -f /etc/calamares/settings.conf ] 2>/dev/null; then
  echo "calamares_install" > "$TARGET/opt/cogos/memory/operator/INSTALL_MODE" 2>/dev/null || true
fi
# d-i late_command overwrites INSTALL_MODE with debian_di_initrd after this hook returns.

# --- Enable native systemd runtime unit (no SysV update-rc.d on d-i) ---
for bin in cogos-runtime-start cogos-runtime-stop; do
  if [ -f "$TARGET/usr/local/bin/$bin" ]; then
    chmod +x "$TARGET/usr/local/bin/$bin"
  fi
done
if [ -x "$TARGET/etc/init.d/90cogos" ]; then
  chmod +x "$TARGET/etc/init.d/90cogos"
fi
enable_target_unit "cogos-runtime.service" "multi-user.target.wants" \
  || log "WARN: cogos-runtime.service not installed on target"
# --- Enable first-boot systemd unit on target ---
if [ -x "$TARGET/usr/local/bin/cogos-first-boot" ] && [ -f "$TARGET/etc/systemd/system/cogos-first-boot.service" ]; then
  enabled=0
  if run_in_target systemctl enable cogos-first-boot.service >>"$LOG" 2>&1; then
    enabled=1
    log "enabled cogos-first-boot.service via systemctl"
  fi
  if [ "$enabled" = "0" ]; then
    mkdir -p "$TARGET/etc/systemd/system/graphical.target.wants"
    ln -sf ../cogos-first-boot.service \
      "$TARGET/etc/systemd/system/graphical.target.wants/cogos-first-boot.service"
    log "enabled cogos-first-boot.service via symlink (Calamares chroot fallback)"
  fi
fi

if [ -f "$TARGET/etc/default/grub" ]; then
  if grep -q '^GRUB_DISTRIBUTOR=' "$TARGET/etc/default/grub"; then
    sed -i 's/^GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="Wolf CoG OS"/' "$TARGET/etc/default/grub"
  else
    echo 'GRUB_DISTRIBUTOR="Wolf CoG OS"' >> "$TARGET/etc/default/grub"
  fi
fi

log "install finish complete — reboot to internal disk for Wolf CoG OS takeover"
exit 0
