{
  "name": "Wolf CoG OS Daily Driver",
  "version": "1.0",
  "principle": "Real daily use: absorb what billions hate about Linux, Windows, and macOS — fix it in infrastructure, not demos. Governance stays silent until something actually matters.",
  "mode": {
    "profile": "daily_driver",
    "enabled_by_default_after_first_run": true,
    "trust_target_band": "daily_driver",
    "operator_stance": "trust_operator"
  },
  "pain_points": [
    {"id": "forced_reboot_updates", "os": ["windows"], "category": "updates", "hate": "Forced reboots and update roulette", "remedy": "signed_channel_guarded_apply", "priority": "critical"},
    {"id": "update_breaks_system", "os": ["windows", "linux", "macos"], "category": "updates", "hate": "Updates that break boot or apps", "remedy": "immune_heal_plus_backup_before_apply", "priority": "critical"},
    {"id": "telemetry_spyware", "os": ["windows", "macos"], "category": "privacy", "hate": "Telemetry and background spying", "remedy": "no_phoning_home_default", "priority": "critical"},
    {"id": "bloatware_nags", "os": ["windows", "macos"], "category": "ux", "hate": "Bloatware, ads, and subscription nags", "remedy": "silent_governance_no_nag_ui", "priority": "high"},
    {"id": "settings_scattered", "os": ["windows", "linux"], "category": "ux", "hate": "Settings split across a dozen panels", "remedy": "control_center_single_pane", "priority": "high"},
    {"id": "terminal_for_basic_fix", "os": ["linux"], "category": "ux", "hate": "Need terminal to fix Wi-Fi, drivers, or permissions", "remedy": "cogos_doctor_and_immune_auto_heal", "priority": "critical"},
    {"id": "driver_lottery", "os": ["linux"], "category": "hardware", "hate": "Wi-Fi, GPU, sleep, and Bluetooth lottery", "remedy": "hardware_veto_log_safe_boot_profile", "priority": "critical"},
    {"id": "suspend_broken", "os": ["linux", "windows"], "category": "hardware", "hate": "Sleep/resume fails or kills Wi-Fi", "remedy": "boot_diagnose_and_immune_medium_heal", "priority": "high"},
    {"id": "package_fragmentation", "os": ["linux"], "category": "apps", "hate": "deb/snap/flatpak/appimage confusion", "remedy": "cogos_pkg_curated_catalog", "priority": "high"},
    {"id": "no_rollback", "os": ["linux", "windows"], "category": "storage", "hate": "No sane rollback after a bad change", "remedy": "cogos_backup_export_and_recovery_mode", "priority": "critical"},
    {"id": "data_loss_fear", "os": ["windows", "macos", "linux"], "category": "storage", "hate": "Fear of losing files or cloud lock-in", "remedy": "cogosdata_local_persistence", "priority": "critical"},
    {"id": "onedrive_icloud_nag", "os": ["windows", "macos"], "category": "storage", "hate": "Cloud storage nagging and sync hijacks", "remedy": "local_first_cogosdata_no_cloud_default", "priority": "high"},
    {"id": "license_activation", "os": ["windows", "macos"], "category": "lock_in", "hate": "License keys and activation walls", "remedy": "no_activation_free_os", "priority": "medium"},
    {"id": "repair_locked", "os": ["macos", "windows"], "category": "lock_in", "hate": "Cannot repair or upgrade hardware yourself", "remedy": "open_installer_and_persist_partition", "priority": "medium"},
    {"id": "registry_config_rot", "os": ["windows", "linux"], "category": "stability", "hate": "Mystery config rot over time", "remedy": "unified_verify_and_governance_registry", "priority": "critical"},
    {"id": "permission_sudo_confusion", "os": ["linux", "macos"], "category": "ux", "hate": "sudo/password prompts with no context", "remedy": "operator_trust_bands_and_voice_confirm_only_danger", "priority": "high"},
    {"id": "defender_false_positive", "os": ["windows"], "category": "security", "hate": "AV false positives blocking real work", "remedy": "immune_severity_not_av_nag", "priority": "high"},
    {"id": "context_menu_bloat", "os": ["windows"], "category": "ux", "hate": "Right-click menus stuffed with junk", "remedy": "minimal_desktop_shell", "priority": "medium"},
    {"id": "slow_boot_creep", "os": ["windows", "linux"], "category": "performance", "hate": "Boot gets slower every month", "remedy": "metal_baseline_and_boot_verify", "priority": "high"},
    {"id": "battery_drain_background", "os": ["windows", "macos", "linux"], "category": "performance", "hate": "Background apps draining battery", "remedy": "daemon_governed_autostart_only_needed", "priority": "high"},
    {"id": "gaming_anticheat_linux", "os": ["linux"], "category": "apps", "hate": "Games and anti-cheat block Linux", "remedy": "wine_wolf_bridge_windows_exe_launcher", "priority": "medium"},
    {"id": "windows_app_gap", "os": ["linux"], "category": "apps", "hate": "Must-have Windows apps missing on Linux", "remedy": "wine_wolf_bridge_windows_exe_launcher", "priority": "high"},
    {"id": "finder_explorer_clunk", "os": ["macos", "windows"], "category": "ux", "hate": "File manager fights you", "remedy": "cogos_desktop_files_api", "priority": "medium"},
    {"id": "dual_boot_bootloader_fear", "os": ["linux", "windows"], "category": "storage", "hate": "Dual-boot or install wipes the wrong disk", "remedy": "cogos_install_plan_validate_confirm", "priority": "critical"},
    {"id": "printer_scanner_hell", "os": ["linux"], "category": "hardware", "hate": "Printers and scanners never work", "remedy": "driver_policy_governed_log", "priority": "medium"},
    {"id": "hidpi_scaling", "os": ["linux", "windows"], "category": "ux", "hate": "Blurry or tiny UI on high-DPI screens", "remedy": "cinnamon_desktop_baseline", "priority": "medium"},
    {"id": "account_required", "os": ["windows", "macos"], "category": "lock_in", "hate": "Microsoft/Apple account required to use your PC", "remedy": "local_operator_profile_no_account", "priority": "high"},
    {"id": "notification_storm", "os": ["windows", "macos", "linux"], "category": "ux", "hate": "Notification spam from OS and apps", "remedy": "silent_governance_immune_notify_medium_plus", "priority": "high"},
    {"id": "mystery_crash_bsod", "os": ["windows", "linux", "macos"], "category": "stability", "hate": "Mystery crashes with no useful trail", "remedy": "immune_ledger_and_boot_diagnose_export", "priority": "critical"},
    {"id": "lost_work_no_autosave", "os": ["windows", "linux", "macos"], "category": "storage", "hate": "Lost work after crash or bad update", "remedy": "cogosdata_persist_and_backup_reminder", "priority": "high"}
  ],
  "remedies": {
    "signed_channel_guarded_apply": {"action": "verify_signed_manifests", "cli": "cogos-manifest verify config/update_channel.json"},
    "immune_heal_plus_backup_before_apply": {"action": "immune_status", "cli": "cogos-immune status", "backup_hint": "cogos-backup export"},
    "no_phoning_home_default": {"action": "local_only_default", "note": "No telemetry channel in update_channel; operator data stays on COGOSDATA"},
    "silent_governance_no_nag_ui": {"action": "apply_silent_governance", "sets": ["bubble_suppressed", "voice_off_by_default"]},
    "control_center_single_pane": {"action": "desktop_autostart", "cli": "cogos-desktop-start", "url": "http://127.0.0.1:8081"},
    "cogos_doctor_and_immune_auto_heal": {"action": "doctor_check", "cli": "cogos-doctor"},
    "hardware_veto_log_safe_boot_profile": {"action": "hardware_veto_status", "cli": "cogos-hardware-veto status"},
    "boot_diagnose_and_immune_medium_heal": {"action": "boot_diagnose", "cli": "cogos-boot-diagnose"},
    "cogos_pkg_curated_catalog": {"action": "pkg_catalog", "cli": "cogos-pkg list"},
    "cogos_backup_export_and_recovery_mode": {"action": "backup_check", "cli": "cogos-backup export", "recovery": "cogos-recovery status"},
    "cogosdata_local_persistence": {"action": "persist_status", "cli": "cogos-persist status", "install": "cogos-install plan"},
    "local_first_cogosdata_no_cloud_default": {"action": "persist_status", "note": "State on COGOSDATA; no iCloud/OneDrive integration"},
    "no_activation_free_os": {"action": "static_ok", "note": "Debian base; no activation layer"},
    "open_installer_and_persist_partition": {"action": "install_available", "cli": "cogos-install plan"},
    "unified_verify_and_governance_registry": {"action": "unified_verify", "cli": "cogos-unified-verify"},
    "operator_trust_bands_and_voice_confirm_only_danger": {"action": "trust_status", "config": "operator_trust_policy.json"},
    "immune_severity_not_av_nag": {"action": "immune_status", "note": "Severity-scored immune; no AV popups"},
    "minimal_desktop_shell": {"action": "desktop_shell", "cli": "cogos-desktop-start"},
    "metal_baseline_and_boot_verify": {"action": "boot_verify", "cli": "cogos-master-boot status"},
    "daemon_governed_autostart_only_needed": {"action": "boot_profile_check", "config": "boot_profile.json"},
    "wine_wolf_bridge_windows_exe_launcher": {"action": "wine_bridge_status", "cli": "cogos-wine-bridge status"},
    "cogos_desktop_files_api": {"action": "desktop_files", "url": "http://127.0.0.1:8081/#files"},
    "cogos_install_plan_validate_confirm": {"action": "install_guard", "cli": "cogos-install plan"},
    "driver_policy_governed_log": {"action": "driver_policy", "config": "driver policy via HAL"},
    "cinnamon_desktop_baseline": {"action": "static_ok", "note": "Debian Cinnamon live base"},
    "local_operator_profile_no_account": {"action": "users_profile", "config": "users.json"},
    "silent_governance_immune_notify_medium_plus": {"action": "apply_silent_governance", "immune_floor": "medium"},
    "immune_ledger_and_boot_diagnose_export": {"action": "immune_ledger", "cli": "cogos-immune status"},
    "cogosdata_persist_and_backup_reminder": {"action": "backup_stale_check", "max_age_hours": 168}
  },
  "silent_governance": {
    "bubble_suppressed": true,
    "voice_enabled_by_default": false,
    "immune_notify_floor": "medium",
    "trust_confirm_only_dangerous": true,
    "desktop_autostart": true,
    "dashboard_autostart": false,
    "auto_daily_on_boot": true
  },
  "boot_apply": [
    "enable_daily_driver_state",
    "patch_boot_profile",
    "apply_silent_governance_prefs"
  ],
  "daily_routine": [
    {"step": "unified_verify", "cli": "cogos-unified-verify", "fail_closed": false},
    {"step": "immune_status", "cli": "cogos-immune status", "auto_heal_if_eligible": true},
    {"step": "persist_status", "cli": "cogos-persist status", "warn_if_ephemeral": true},
    {"step": "backup_stale_check", "max_age_hours": 168, "cli": "cogos-backup export"},
    {"step": "trust_status", "target_band": "daily_driver"},
    {"step": "auto_suggest", "cli": "cogos-auto suggest"},
    {"step": "audit_pain_gaps", "warn_only": true}
  ],
  "state_path": "memory/runtime/daily_driver_state.json",
  "events_path": "memory/runtime/daily_driver_events.jsonl"
}
