{
  "name": "CoGOS Boot Governance Policy",
  "version": "1.0",
  "principle": "During firstboot bootstrap, substrate identity services run under grace — governance must not treat them as untrusted identity mutation.",
  "firstboot_grace": {
    "until_marker_cleared": true,
    "marker_paths": [
      "/opt/cogos/memory/operator/FIRST_BOOT_PENDING",
      "/var/lib/cogos/memory/operator/FIRST_BOOT_PENDING"
    ],
    "recent_grace_seconds": 900,
    "recent_grace_stamp": "/var/lib/cogos/BOOTSTRAP_GRACE_UNTIL",
    "systemd_units": {
      "accounts-daemon.service": "grace",
      "systemd-logind.service": "grace",
      "dbus.service": "grace",
      "polkit.service": "grace",
      "systemd-user-sessions.service": "grace"
    }
  },
  "dependency_baseline": {
    "required_for_governance": [
      "dbus.service",
      "systemd-logind.service",
      "polkit.service",
      "accounts-daemon.service"
    ]
  }
}
