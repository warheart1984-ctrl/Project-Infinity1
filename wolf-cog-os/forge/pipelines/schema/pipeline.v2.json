{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forge-pipeline.v2",
  "title": "Forge variant pipeline v2",
  "type": "object",
  "required": ["schema_version", "name", "variant", "substrate", "output"],
  "properties": {
    "schema_version": { "const": "forge-pipeline.v2" },
    "name": { "type": "string" },
    "base": { "type": "string" },
    "variant": {
      "type": "object",
      "required": ["id", "channel"],
      "properties": {
        "id": { "type": "string" },
        "channel": { "enum": ["dev", "rc", "stable", "nightly"] }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "parent": { "type": "string" },
        "parent_lineage_id": { "type": "string" }
      }
    },
    "reproducibility": {
      "type": "object",
      "properties": {
        "seed": { "type": "string" },
        "deterministic": { "type": "boolean" }
      }
    },
    "substrate": { "type": "object" },
    "output": { "type": "object" }
  }
}
