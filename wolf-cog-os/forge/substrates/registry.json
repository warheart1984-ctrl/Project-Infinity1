{
  "registry_version": "substrate-registry.v2",
  "default_substrate_id": "generic-live-squashfs",
  "default_contract_version": "forge-substrate.v2",
  "substrate_classes": {
    "generic-live-squashfs": {
      "description": "Fallback class for Debian-style live/ squashfs hybrids",
      "tier": "fallback"
    },
    "debian-family": {
      "description": "Debian-derived live ISO layouts",
      "tier": "distro"
    },
    "ubuntu-family": {
      "description": "Ubuntu live ISO layouts",
      "tier": "distro"
    },
    "arch-family": {
      "description": "Arch Linux archiso layouts",
      "tier": "distro"
    },
    "fedora-family": {
      "description": "Fedora/RHEL LiveOS layouts",
      "tier": "distro"
    },
    "alpine-family": {
      "description": "Alpine live/modloop layouts",
      "tier": "distro"
    },
    "opensuse-family": {
      "description": "openSUSE LiveOS layouts",
      "tier": "distro"
    },
    "cogos-product": {
      "description": "CoGOS-built replay substrates",
      "tier": "product"
    },
    "windows-family": {
      "description": "Windows WIM/WinPE installer media",
      "tier": "distro"
    },
    "macos-family": {
      "description": "macOS APFS installer media",
      "tier": "distro"
    },
    "android-family": {
      "description": "Android bootable/system images",
      "tier": "distro"
    }
  },
  "substrates": {
    "generic-live-squashfs": {
      "description": "Any hybrid live ISO with squashfs root under live/",
      "class": "generic-live-squashfs",
      "family": "generic",
      "contract_version": "forge-substrate.v2",
      "priority": 10,
      "min_bytes": 100000000,
      "replay_adapter": "debian-live-layout",
      "detect": {
        "path_globs": ["live/*.squashfs", "live/filesystem*.squashfs"],
        "path_any": ["live/vmlinuz", "live/initrd", "live/initrd.img"]
      }
    },
    "debian-live": {
      "description": "Debian live hybrid ISO with squashfs root under live/",
      "class": "debian-family",
      "family": "debian",
      "contract_version": "forge-substrate.v2",
      "priority": 40,
      "extends": "generic-live-squashfs",
      "min_bytes": 300000000,
      "replay_adapter": "debian-live-layout",
      "detect": {
        "path_globs": ["live/filesystem.squashfs", "live/filesystem*.squashfs"],
        "path_any": ["live/vmlinuz", "live/initrd.img"],
        "path_markers": ["dists/bookworm", "dists/trixie", "dists/forky", ".disk/info"]
      }
    },
    "ubuntu-live": {
      "description": "Ubuntu desktop/server live ISO",
      "class": "ubuntu-family",
      "family": "ubuntu",
      "contract_version": "forge-substrate.v2",
      "priority": 55,
      "extends": "generic-live-squashfs",
      "min_bytes": 800000000,
      "replay_adapter": "debian-live-layout",
      "detect": {
        "path_globs": ["live/filesystem.squashfs", "casper/filesystem.squashfs"],
        "path_any": ["live/vmlinuz", "casper/vmlinuz"],
        "path_markers": ["dists/jammy", "dists/noble", "dists/mantic", "pool/main/u/ubuntu-meta", "casper/filesystem.manifest"]
      }
    },
    "arch-live": {
      "description": "Arch Linux archiso live image",
      "class": "arch-family",
      "family": "arch",
      "contract_version": "forge-substrate.v2",
      "priority": 50,
      "min_bytes": 400000000,
      "replay_adapter": "archiso-layout",
      "detect": {
        "path_globs": ["arch/*.sfs", "arch/airootfs.sfs", "live/archiso.sfs"],
        "path_any": ["arch/grub", "boot/grub/grub.cfg"],
        "path_markers": [".ARCHISO", "arch/grubenv"]
      }
    },
    "fedora-live": {
      "description": "Fedora Workstation/Server live ISO (LiveOS layout)",
      "class": "fedora-family",
      "family": "fedora",
      "contract_version": "forge-substrate.v2",
      "priority": 50,
      "min_bytes": 900000000,
      "replay_adapter": "fedora-liveos-layout",
      "detect": {
        "path_globs": ["LiveOS/squashfs.img", "LiveOS/ext3fs.img"],
        "path_any": ["images/pxeboot/vmlinuz", "isolinux/vmlinuz", "EFI/BOOT/grub.cfg"],
        "path_markers": ["LiveOS/liveos-flag"]
      }
    },
    "rocky-live": {
      "description": "Rocky Linux live/install ISO (LiveOS squashfs layout)",
      "class": "fedora-family",
      "family": "rocky",
      "contract_version": "forge-substrate.v2",
      "priority": 52,
      "min_bytes": 800000000,
      "replay_adapter": "fedora-liveos-layout",
      "detect": {
        "path_globs": ["LiveOS/squashfs.img", "LiveOS/ext3fs.img", "images/install.img"],
        "path_any": ["images/pxeboot/vmlinuz", "isolinux/vmlinuz", "EFI/BOOT/grub.cfg"],
        "path_markers": [".discinfo", "images/install.img"]
      }
    },
    "alpine-live": {
      "description": "Alpine extended/live ISO",
      "class": "alpine-family",
      "family": "alpine",
      "contract_version": "forge-substrate.v2",
      "priority": 45,
      "min_bytes": 120000000,
      "replay_adapter": "alpine-modloop-layout",
      "detect": {
        "path_globs": ["boot/*.modloop*", "boot/initramfs-*"],
        "path_any": ["boot/vmlinuz-*", "boot/initramfs-lts"],
        "path_markers": ["apks", ".alpine-release"]
      }
    },
    "opensuse-live": {
      "description": "openSUSE Leap/Tumbleweed live ISO",
      "class": "opensuse-family",
      "family": "opensuse",
      "contract_version": "forge-substrate.v2",
      "priority": 48,
      "min_bytes": 900000000,
      "replay_adapter": "fedora-liveos-layout",
      "detect": {
        "path_globs": ["LiveOS/squashfs.img", "LiveOS/system"],
        "path_any": ["boot/x86_64/loader/linux", "EFI/BOOT/grub.cfg"],
        "path_markers": ["README.BETA", "boot/x86_64/config"]
      }
    },
    "cogos-replay": {
      "description": "CoGOS-built hybrid ISO suitable for xorriso boot replay",
      "class": "cogos-product",
      "family": "cogos",
      "contract_version": "forge-substrate.v2",
      "priority": 90,
      "extends": "generic-live-squashfs",
      "min_bytes": 1000000000,
      "replay_adapter": "debian-live-layout",
      "detect": {
        "path_globs": ["live/filesystem.squashfs", "live/filesystem*.squashfs"],
        "path_any": ["live/vmlinuz", "boot/grub/grub.cfg"],
        "path_markers": ["live/filesystem.packages"]
      }
    },
    "trixie-live": {
      "description": "TrixiePup or similar Debian-derived live ISO",
      "class": "debian-family",
      "family": "puppy",
      "contract_version": "forge-substrate.v2",
      "priority": 35,
      "extends": "generic-live-squashfs",
      "min_bytes": 500000000,
      "replay_adapter": "debian-live-layout",
      "detect": {
        "path_globs": ["live/*.squashfs"],
        "path_any": ["live/vmlinuz"],
        "path_markers": ["puppy", "TrixiePup"]
      }
    },
    "windows-installer": {
      "description": "Windows installation media (WIM/ESD + WinPE + BCD)",
      "class": "windows-family",
      "family": "windows",
      "contract_version": "forge-substrate.v2",
      "priority": 60,
      "min_bytes": 4000000000,
      "replay_adapter": "windows-wim-layout",
      "detect": {
        "path_globs": ["sources/install.wim", "sources/install.esd", "sources/boot.wim"],
        "path_any": ["boot/bcd", "efi/microsoft/boot/bcd", "bootmgr", "bootmgr.efi"],
        "path_markers": ["sources/install.wim", "sources/boot.wim", "boot/bcd"]
      }
    },
    "macos-installer": {
      "description": "macOS installer media (BaseSystem.dmg / InstallAssistant)",
      "class": "macos-family",
      "family": "macos",
      "contract_version": "forge-substrate.v2",
      "priority": 58,
      "min_bytes": 500000000,
      "replay_adapter": "macos-apfs-layout",
      "detect": {
        "path_globs": ["BaseSystem.dmg", "InstallAssistant.pkg"],
        "path_any": ["InstallAssistant.app/Contents/SharedSupport/SharedSupport.dmg"],
        "path_markers": ["com.apple.distribution.osinstall", ".IABootFiles"]
      }
    },
    "android-bootable": {
      "description": "Android factory/boot image set (super.img / boot.img / system.img)",
      "class": "android-family",
      "family": "android",
      "contract_version": "forge-substrate.v2",
      "priority": 57,
      "min_bytes": 200000000,
      "replay_adapter": "android-super-layout",
      "detect": {
        "path_globs": ["super.img", "system.img", "boot.img"],
        "path_any": ["vendor.img", "product.img", "vbmeta.img"],
        "path_markers": ["META-INF/com/android/metadata", "payload.bin"]
      }
    }
  }
}
