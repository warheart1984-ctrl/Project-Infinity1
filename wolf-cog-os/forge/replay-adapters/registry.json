{
  "registry_version": "forge-replay-adapter.v1",
  "default_adapter": "debian-live-layout",
  "adapters": {
    "debian-live-layout": {
      "description": "Debian/cogos live/filesystem.squashfs replay via build.sh",
      "status": "production",
      "wired_in_build": true,
      "substrate_families": ["generic", "debian", "puppy", "cogos"]
    },
    "ubuntu-live-layout": {
      "description": "Ubuntu live layout (delegates to debian-live-layout paths)",
      "status": "production",
      "wired_in_build": true,
      "substrate_families": ["ubuntu"]
    },
    "archiso-layout": {
      "description": "Arch Linux archiso .sfs replay",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["arch"]
    },
    "fedora-liveos-layout": {
      "description": "Fedora/openSUSE LiveOS/squashfs.img replay",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["fedora", "opensuse"]
    },
    "alpine-modloop-layout": {
      "description": "Alpine modloop-based live replay",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["alpine"]
    },
    "windows-wim-layout": {
      "description": "Windows WIM/ESD + WinPE + BCD replay (wimlib)",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["windows"],
      "required_tools": ["wimapply"],
      "governance_invariants": ["bcd_integrity", "signature_preservation", "boot_chain_order"]
    },
    "macos-apfs-layout": {
      "description": "macOS APFS / Installer.app replay",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["macos"],
      "required_tools": ["hdiutil"],
      "governance_invariants": ["apfs_integrity", "sealed_snapshot_verification", "signature_preservation"]
    },
    "android-super-layout": {
      "description": "Android super.img / dynamic partition replay",
      "status": "experimental",
      "wired_in_build": true,
      "substrate_families": ["android"],
      "required_tools": ["lpunpack"],
      "governance_invariants": ["selinux_label_consistency", "avb_vbmeta_awareness", "ab_slot_metadata"]
    }
  }
}
