{
  "registry_version": "rootfs-backend-registry.v1",
  "default_backend_id": "debootstrap",
  "default_contract_version": "forge-rootfs-backend.v1",
  "backend_classes": {
    "debian-family": {
      "description": "Debian-derived bootstrap tooling",
      "tier": "production"
    },
    "arch-family": {
      "description": "Arch Linux pacstrap tooling",
      "tier": "production"
    },
    "rpm-family": {
      "description": "Fedora/RHEL dnf bootstrap tooling",
      "tier": "planned"
    },
    "alpine-family": {
      "description": "Alpine apk bootstrap tooling",
      "tier": "planned"
    },
    "windows-family": {
      "description": "Windows WinPE inject backend",
      "tier": "experimental"
    },
    "macos-family": {
      "description": "macOS darwin overlay backend",
      "tier": "experimental"
    },
    "android-family": {
      "description": "Android overlay/repack backend",
      "tier": "experimental"
    }
  },
  "backends": {
    "debootstrap": {
      "description": "Debian debootstrap minbase rootfs creation",
      "class": "debian-family",
      "implementation_status": "production",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "apt",
      "supported_arches": ["amd64", "arm64"],
      "required_tools": ["debootstrap"],
      "env": {
        "suite": "COGOS_DEBIAN_SUITE",
        "mirror": "COGOS_MIRROR",
        "arch": "COGOS_ARCH"
      },
      "defaults": {
        "suite": "trixie",
        "mirror": "http://deb.debian.org/debian",
        "arch": "amd64"
      }
    },
    "pacstrap": {
      "description": "Arch Linux pacstrap rootfs creation",
      "class": "arch-family",
      "implementation_status": "production",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "pacman",
      "supported_arches": ["x86_64", "aarch64"],
      "required_tools": ["pacstrap", "arch-chroot"],
      "env": {
        "mirror": "COGOS_ARCH_MIRROR",
        "arch": "COGOS_ARCH"
      },
      "defaults": {
        "mirror": "https://geo.mirror.pkgbuild.com/",
        "arch": "x86_64"
      }
    },
    "dnfroot": {
      "description": "Fedora/RHEL dnf --installroot bootstrap",
      "class": "rpm-family",
      "implementation_status": "stub",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "dnf",
      "supported_arches": ["x86_64", "aarch64"],
      "required_tools": ["dnf"],
      "env": {
        "release": "COGOS_DNF_RELEASE",
        "mirror": "COGOS_DNF_MIRROR",
        "arch": "COGOS_ARCH"
      },
      "defaults": {
        "release": "fedora-41",
        "mirror": "",
        "arch": "x86_64"
      }
    },
    "apkroot": {
      "description": "Alpine apk bootstrap rootfs creation",
      "class": "alpine-family",
      "implementation_status": "stub",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "apk",
      "supported_arches": ["x86_64", "aarch64"],
      "required_tools": ["apk"],
      "env": {
        "release": "COGOS_ALPINE_RELEASE",
        "mirror": "COGOS_ALPINE_MIRROR",
        "arch": "COGOS_ARCH"
      },
      "defaults": {
        "release": "edge",
        "mirror": "https://dl-cdn.alpinelinux.org/alpine",
        "arch": "x86_64"
      }
    },
    "winpe-backend": {
      "description": "Windows WinPE inject backend (drivers, registry, provisioning)",
      "class": "windows-family",
      "implementation_status": "experimental",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "inject",
      "mode": "inject-only",
      "supported_arches": ["amd64", "arm64"],
      "required_tools": [],
      "env": {
        "manifest": "COGOS_INJECT_MANIFEST"
      },
      "defaults": {
        "manifest": "wolf-cog-os/config/overlays/windows-inject/manifest.json"
      },
      "governance_invariants": ["bcd_integrity", "signature_preservation", "boot_chain_order"]
    },
    "darwin-backend": {
      "description": "macOS darwin overlay backend (LaunchDaemons, profiles)",
      "class": "macos-family",
      "implementation_status": "experimental",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "inject",
      "mode": "inject-only",
      "supported_arches": ["x86_64", "arm64"],
      "required_tools": [],
      "env": {
        "manifest": "COGOS_INJECT_MANIFEST"
      },
      "defaults": {
        "manifest": "wolf-cog-os/config/overlays/macos-inject/manifest.json"
      },
      "governance_invariants": ["apfs_integrity", "sealed_snapshot_verification"]
    },
    "android-backend": {
      "description": "Android overlay/repack backend (system/vendor/init)",
      "class": "android-family",
      "implementation_status": "experimental",
      "contract_version": "forge-rootfs-backend.v1",
      "package_manager": "inject",
      "mode": "inject-only",
      "supported_arches": ["x86_64", "arm64", "aarch64"],
      "required_tools": [],
      "env": {
        "manifest": "COGOS_INJECT_MANIFEST"
      },
      "defaults": {
        "manifest": "wolf-cog-os/config/overlays/android-inject/manifest.json"
      },
      "governance_invariants": ["selinux_label_consistency", "avb_vbmeta_awareness"]
    }
  }
}
