{
  "registry_version": "forge-arch-matrix.v1",
  "default_arch": "amd64",
  "contract_version": "forge-platform.v1",
  "arches": {
    "amd64": {
      "description": "x86_64 primary build target",
      "status": "production",
      "debootstrap_arch": "amd64",
      "qemu_system": "x86_64",
      "cloud_outputs": ["raw-img", "qcow2", "vhd", "ami"],
      "substrate_replay": ["debian-live-layout", "cogos-replay"]
    },
    "arm64": {
      "description": "aarch64 cross-build target",
      "status": "experimental",
      "debootstrap_arch": "arm64",
      "qemu_system": "aarch64",
      "cloud_outputs": ["raw-img", "qcow2", "ami"],
      "substrate_replay": ["debian-live-layout"]
    },
    "riscv64": {
      "description": "RISC-V experimental target",
      "status": "planned",
      "debootstrap_arch": "riscv64",
      "qemu_system": "riscv64",
      "cloud_outputs": ["raw-img"],
      "substrate_replay": []
    }
  },
  "backend_arch_map": {
    "debootstrap": {
      "amd64": "amd64",
      "arm64": "arm64",
      "riscv64": "riscv64"
    },
    "pacstrap": {
      "amd64": "x86_64",
      "arm64": "aarch64"
    },
    "dnfroot": {
      "amd64": "x86_64",
      "arm64": "aarch64"
    },
    "apkroot": {
      "amd64": "x86_64",
      "arm64": "aarch64"
    },
    "winpe-backend": {
      "amd64": "amd64",
      "arm64": "arm64"
    },
    "darwin-backend": {
      "amd64": "x86_64",
      "arm64": "aarch64"
    },
    "android-backend": {
      "amd64": "x86_64",
      "arm64": "arm64",
      "aarch64": "aarch64"
    }
  }
}
