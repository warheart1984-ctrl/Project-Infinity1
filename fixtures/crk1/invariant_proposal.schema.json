{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/invariant-proposal.v1.json",
  "title": "InvariantProposal",
  "type": "object",
  "required": ["id", "type", "created_at", "created_by", "epoch", "payload", "links"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "InvariantProposal" },
    "created_at": { "type": "string" },
    "created_by": { "type": "string" },
    "epoch": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": [
        "label",
        "statement",
        "motivation_cf_events",
        "gap_in_existing_invariants",
        "expected_effect_on_ce_se"
      ],
      "properties": {
        "label": { "type": "string" },
        "statement": { "type": "string" },
        "motivation_cf_events": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gap_in_existing_invariants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_effect_on_ce_se": {
          "type": "object",
          "properties": {
            "ce_s_min": { "type": "number" },
            "se_s_min": { "type": "number" }
          }
        }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "drift_observation_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "test_suite_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
