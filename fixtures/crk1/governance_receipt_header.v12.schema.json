{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/governance-receipt-header.v1.2.json",
  "title": "CRK-1 Governance Receipt Header v1.2",
  "type": "object",
  "properties": {
    "receipt_id": { "type": "string" },
    "runtime_version": {
      "type": "string",
      "pattern": "^CRK-1 v[0-9]+\\.[0-9]+$"
    },
    "epoch": { "type": "integer", "minimum": 0 },
    "action_type": {
      "type": "string",
      "enum": ["mutation", "certification", "governance_decision"]
    },
    "actor_identity": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "kernel_state_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "ledger_state_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "invariants_checked": {
      "type": "object",
      "properties": {
        "K0_K2": { "type": "string", "enum": ["PASS", "FAIL"] },
        "K3_K6": { "type": "string", "enum": ["PASS", "FAIL"] },
        "K7_K12": { "type": "string", "enum": ["PASS", "FAIL"] },
        "K13_K15": { "type": "string", "enum": ["PASS", "FAIL"] },
        "KΩ": { "type": "string", "enum": ["PASS", "FAIL"] }
      },
      "required": ["K0_K2", "K3_K6", "K7_K12"],
      "additionalProperties": false
    },
    "drift_metrics": {
      "type": "object",
      "properties": {
        "CE_before": { "type": "number" },
        "CE_after": { "type": "number" },
        "SE_before": { "type": "number" },
        "SE_after": { "type": "number" },
        "RAI_before": { "type": "number" },
        "RAI_after": { "type": "number" }
      },
      "required": ["CE_before", "CE_after", "SE_before", "SE_after"],
      "additionalProperties": false
    },
    "redteam_status": {
      "type": "object",
      "properties": {
        "attacks_run": {
          "type": "array",
          "items": { "type": "string", "enum": ["B1", "B2", "B3"] }
        },
        "all_blocked": { "type": "string", "enum": ["YES", "NO"] }
      },
      "required": ["attacks_run", "all_blocked"]
    },
    "decision_summary": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "invariant_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "linked_grr_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "kernel_challenge_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signatures": {
      "type": "object",
      "properties": {
        "governance_body": { "type": "string" },
        "external_operator": { "type": "string" }
      },
      "required": ["governance_body"]
    }
  },
  "required": [
    "receipt_id",
    "runtime_version",
    "epoch",
    "action_type",
    "actor_identity",
    "timestamp",
    "kernel_state_hash",
    "ledger_state_hash",
    "invariants_checked",
    "drift_metrics",
    "redteam_status",
    "decision_summary",
    "evidence_refs",
    "signatures"
  ],
  "additionalProperties": false
}
