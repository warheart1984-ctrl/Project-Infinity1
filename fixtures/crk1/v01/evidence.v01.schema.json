{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/v01/evidence.v01.json",
  "title": "CRK1EvidenceV01",
  "allOf": [
    { "$ref": "envelope.definitions.schema.json#/$defs/envelopeBase" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "Evidence" },
        "payload": {
          "type": "object",
          "required": ["label", "kind"],
          "properties": {
            "label": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["Log", "Metric", "Document", "TestResult", "Other"]
            },
            "uri": { "type": "string" },
            "summary": { "type": "string" },
            "hash": { "type": "string" },
            "attributes": { "type": "object" }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "object",
          "properties": {
            "outcome_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "decision_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "interpretation_ids": {
              "type": "array",
              "items": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
