{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/v01/envelope.definitions.schema.json",
  "$defs": {
    "objectId": {
      "type": "string",
      "minLength": 1,
      "description": "Globally unique CRK-1 wire id, e.g. I-0001, D-0001, R-1005"
    },
    "objectType": {
      "type": "string",
      "enum": ["Identity", "Decision", "Outcome", "Evidence", "Interpretation", "Receipt"]
    },
    "isoTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "envelopeBase": {
      "type": "object",
      "required": ["id", "type", "created_at", "created_by", "epoch", "receipt_id", "payload", "links"],
      "properties": {
        "id": { "$ref": "#/$defs/objectId" },
        "type": { "$ref": "#/$defs/objectType" },
        "created_at": { "$ref": "#/$defs/isoTimestamp" },
        "created_by": { "type": "string", "minLength": 1 },
        "epoch": { "type": "integer", "minimum": 0 },
        "receipt_id": { "$ref": "#/$defs/objectId" },
        "payload": { "type": "object" },
        "links": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
