{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/v01/identity.v01.json",
  "title": "CRK1IdentityV01",
  "allOf": [
    { "$ref": "envelope.definitions.schema.json#/$defs/envelopeBase" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "Identity" },
        "payload": {
          "type": "object",
          "required": ["label", "kind"],
          "properties": {
            "label": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["Person", "Organization", "System", "Process", "Other"]
            },
            "attributes": { "type": "object" }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "object",
          "properties": {
            "decisions": {
              "type": "array",
              "items": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
