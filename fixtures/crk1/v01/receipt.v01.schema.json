{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/v01/receipt.v01.json",
  "title": "CRK1ReceiptV01",
  "allOf": [
    { "$ref": "envelope.definitions.schema.json#/$defs/envelopeBase" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "Receipt" },
        "payload": {
          "type": "object",
          "required": ["action_type", "object_type", "object_id"],
          "properties": {
            "action_type": { "type": "string" },
            "object_type": { "$ref": "envelope.definitions.schema.json#/$defs/objectType" },
            "object_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "kernel_version": { "type": "string" },
            "invariant_results": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "status"],
                "properties": {
                  "id": { "type": "string" },
                  "status": { "type": "string", "enum": ["Pass", "Fail", "Skip"] }
                }
              }
            },
            "drift_snapshot": {
              "type": "object",
              "properties": {
                "ce_s": { "type": "number" },
                "se_s": { "type": "number" }
              }
            },
            "signatures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["by", "kind", "signature", "at"],
                "properties": {
                  "by": { "type": "string" },
                  "kind": { "type": "string" },
                  "signature": { "type": "string" },
                  "at": { "$ref": "envelope.definitions.schema.json#/$defs/isoTimestamp" }
                }
              }
            }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "object",
          "properties": {
            "object_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "identity_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "decision_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "evidence_ids": {
              "type": "array",
              "items": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" }
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
