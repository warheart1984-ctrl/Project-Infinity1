{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/v01/interpretation.v01.json",
  "title": "CRK1InterpretationV01",
  "allOf": [
    { "$ref": "envelope.definitions.schema.json#/$defs/envelopeBase" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "Interpretation" },
        "payload": {
          "type": "object",
          "required": ["label", "statement", "confidence"],
          "properties": {
            "label": { "type": "string" },
            "statement": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "assumptions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "invariant_checks": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "object",
          "properties": {
            "evidence_ids": {
              "type": "array",
              "items": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" }
            },
            "decision_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" },
            "identity_id": { "$ref": "envelope.definitions.schema.json#/$defs/objectId" }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
