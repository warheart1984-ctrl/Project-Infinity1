{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "EvidenceObject",
  "title": "EvidenceObject",
  "type": "object",
  "required": ["id", "source_type", "admissible_for_decision", "created_at"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "source_type": {
      "type": "string",
      "enum": ["reality", "outcome", "external_ledger"]
    },
    "source_outcome_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "admissible_for_decision": {
      "type": "boolean",
      "const": true
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "source_type": { "const": "outcome" } } },
      "then": { "required": ["source_outcome_id"] }
    }
  ],
  "additionalProperties": false
}
