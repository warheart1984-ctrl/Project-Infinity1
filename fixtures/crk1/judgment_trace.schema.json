{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "JudgmentTrace",
  "title": "JudgmentTrace",
  "type": "object",
  "required": [
    "evidence",
    "context",
    "reasoning",
    "uncertainty",
    "thresholds",
    "outcomes",
    "correction"
  ],
  "properties": {
    "evidence": {
      "type": "object",
      "required": ["raw"],
      "properties": {
        "raw": {}
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["stateSummary"],
      "properties": {
        "stateSummary": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": false
    },
    "reasoning": {
      "type": "object",
      "required": ["interpretation", "justification"],
      "properties": {
        "interpretation": { "type": "string" },
        "justification": { "type": "string" }
      },
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensions": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": false
    },
    "thresholds": {
      "type": "object",
      "required": ["values"],
      "properties": {
        "values": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": false
    },
    "outcomes": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": { "type": "object" }
      },
      "additionalProperties": false
    },
    "correction": {
      "type": "object",
      "required": ["postCorrectionState"],
      "properties": {
        "postCorrectionState": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
