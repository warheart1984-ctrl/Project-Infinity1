{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/kernel-challenge-receipt.v1.json",
  "title": "KernelChallengeReceipt",
  "type": "object",
  "required": ["id", "type", "created_at", "created_by", "epoch", "payload", "links"],
  "properties": {
    "id": { "type": "string", "pattern": "^KCR-[0-9]+$" },
    "type": { "const": "KernelChallengeReceipt" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "epoch": { "type": "integer", "minimum": 0 },
    "payload": {
      "type": "object",
      "required": [
        "challenge_id",
        "kernel_version_before",
        "status",
        "reason",
        "cf_events",
        "receipts_implicated",
        "invariants_challenged",
        "proposed_changes",
        "validation_process"
      ],
      "properties": {
        "challenge_id": { "type": "string" },
        "kernel_version_before": { "type": "string" },
        "kernel_version_after": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["Accepted", "Rejected", "Pending"]
        },
        "reason": { "type": "string" },
        "cf_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "silent_failure": { "type": "boolean" }
            }
          }
        },
        "receipts_implicated": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "invariants_challenged": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proposed_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "target", "diff"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["Amendment", "Retirement", "Addition"]
              },
              "target": { "type": "string" },
              "diff": { "type": "string" }
            }
          }
        },
        "validation_process": {
          "type": "object",
          "required": ["steps", "result"],
          "properties": {
            "steps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "result": {
              "type": "string",
              "enum": ["Sufficient", "Insufficient"]
            }
          }
        }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "cf_event_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "receipt_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "old_kernel_id": { "type": "string" },
        "new_kernel_id": { "type": "string" }
      }
    }
  }
}
