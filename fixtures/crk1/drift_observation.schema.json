{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/drift-observation.v1.json",
  "title": "DriftObservation",
  "type": "object",
  "required": ["id", "type", "created_at", "created_by", "epoch", "payload", "links"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "DriftObservation" },
    "created_at": { "type": "string" },
    "created_by": { "type": "string" },
    "epoch": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["metric", "value", "baseline", "window", "description"],
      "properties": {
        "metric": { "enum": ["CE(S)", "SE(S)"] },
        "value": { "type": "number" },
        "baseline": { "type": "number" },
        "window": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "cf_event_ids": { "type": "array", "items": { "type": "string" } },
        "receipt_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
