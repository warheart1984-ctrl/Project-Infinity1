{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/reproduction-packet.v1.json",
  "title": "ReproductionPacket",
  "type": "object",
  "required": ["id", "type", "created_at", "created_by", "payload", "links"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "ReproductionPacket" },
    "created_at": { "type": "string" },
    "created_by": { "type": "string" },
    "epoch": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["version", "contents"],
      "properties": {
        "version": { "type": "string" },
        "packet_fingerprint": { "type": "string" },
        "artifacts_verified": { "type": "boolean" },
        "contents": {
          "type": "object",
          "properties": {
            "spec_docs": { "type": "array", "items": { "type": "string" } },
            "reference_implementation": {
              "type": "array",
              "items": { "type": "string" }
            },
            "test_harness": { "type": "array", "items": { "type": "string" } },
            "reproduction_instructions": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "kernel_id": { "type": "string" },
        "test_suite_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
