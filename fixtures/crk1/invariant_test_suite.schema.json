{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/invariant-test-suite.v1.json",
  "title": "InvariantTestSuite",
  "type": "object",
  "required": ["id", "type", "created_at", "created_by", "epoch", "payload", "links"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "InvariantTestSuite" },
    "created_at": { "type": "string" },
    "created_by": { "type": "string" },
    "epoch": { "type": "integer" },
    "payload": {
      "type": "object",
      "required": ["label", "scenarios", "results"],
      "properties": {
        "label": { "type": "string" },
        "scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "results": {
          "type": "object",
          "required": ["passed"],
          "properties": {
            "passed": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "invariant_proposal_id": { "type": "string" }
      }
    }
  }
}
