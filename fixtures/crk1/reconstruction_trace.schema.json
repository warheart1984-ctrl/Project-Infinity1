{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crk1.local/schemas/reconstruction-trace.v1.json",
  "title": "ReconstructionTrace",
  "description": "Minimal reconstructability trace — how judgment can be reconstructed, not a log of judgment.",
  "type": "object",
  "required": [
    "generation",
    "cycle",
    "evidence",
    "context",
    "reasoning",
    "uncertainty",
    "thresholds",
    "outcomes",
    "correction"
  ],
  "properties": {
    "generation": {
      "type": "integer",
      "description": "Generation index g."
    },
    "cycle": {
      "type": "integer",
      "description": "Cycle index within generation."
    },
    "evidence": {
      "type": "object",
      "description": "What reality provided.",
      "required": ["raw"],
      "properties": {
        "raw": {},
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timestamp": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "description": "Semantic frame of judgment.",
      "required": ["stateSummary"],
      "properties": {
        "stateSummary": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "relevantHistory": {
          "type": "array",
          "items": { "type": "object" }
        },
        "environment": { "type": "object" }
      }
    },
    "reasoning": {
      "type": "object",
      "description": "How evidence was interpreted and why.",
      "required": ["interpretation", "justification"],
      "properties": {
        "interpretation": { "type": "string" },
        "justification": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "description": "Known, estimated, and unknown quantities.",
      "required": ["confidence"],
      "properties": {
        "estimates": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unknowns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "description": "Decision rules and trigger conditions.",
      "required": ["decisionRule", "triggered"],
      "properties": {
        "decisionRule": { "type": "string" },
        "triggered": { "type": "boolean" },
        "parameters": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "outcomes": {
      "type": "object",
      "description": "Ground-truth anchor after judgment.",
      "required": ["result"],
      "properties": {
        "result": { "type": "object" },
        "measuredEvidence": { "type": "object" },
        "deltaFromExpectation": { "type": "object" }
      }
    },
    "correction": {
      "type": "object",
      "description": "Corrigibility / reflection record.",
      "required": ["veto", "correctionApplied"],
      "properties": {
        "veto": { "type": "boolean" },
        "correctionApplied": { "type": "boolean" },
        "correctionType": { "type": "string" },
        "postCorrectionState": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    }
  },
  "additionalProperties": false
}
