{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "UGR/OUT-1.md#OutcomeObject/v0.1.0",
  "title": "OutcomeObject",
  "type": "object",
  "required": [
    "id",
    "decision_id",
    "expected",
    "observed",
    "variance",
    "lessons",
    "epoch",
    "timestamp",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "decision_id": { "type": "string" },
    "expected": { "type": "object" },
    "observed": { "type": "object" },
    "variance": { "type": "object" },
    "lessons": { "type": "array", "items": { "type": "string" } },
    "epoch": { "type": "integer" },
    "timestamp": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["recorded", "disputed", "superseded"]
    }
  },
  "additionalProperties": false
}
