{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ROOT/LAW-LEDGER.md#LawRecord/v1.0.0",
  "title": "LawRecord",
  "description": "Canonical object stored in the Law Ledger",
  "type": "object",
  "required": [
    "law_id",
    "version",
    "law_hash",
    "spec_ref",
    "status",
    "created_at_epoch",
    "introduced_by",
    "fitness",
    "domains",
    "dependencies",
    "conflicts",
    "supersedes"
  ],
  "properties": {
    "law_id": { "type": "string" },
    "version": { "type": "string" },
    "law_hash": { "type": "string" },
    "spec_ref": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "experimental",
        "admitted",
        "quarantined",
        "deprecated",
        "revoked"
      ]
    },
    "created_at_epoch": { "type": "integer" },
    "introduced_by": { "type": "string" },
    "fitness": {
      "type": "object",
      "required": ["current", "history", "thresholds"],
      "properties": {
        "current": { "type": "number" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["epoch", "F", "sample_size", "notes"],
            "properties": {
              "epoch": { "type": "integer" },
              "F": { "type": "number" },
              "sample_size": { "type": "integer" },
              "notes": { "type": "string" }
            }
          }
        },
        "thresholds": {
          "type": "object",
          "required": ["admit", "reject"],
          "properties": {
            "admit": { "type": "number" },
            "reject": { "type": "number" }
          }
        }
      }
    },
    "domains": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": "array", "items": { "type": "string" } }
  }
}
