{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CRK-1.md#ResourceObject/v0.1.0",
  "title": "ResourceObject",
  "type": "object",
  "required": [
    "id",
    "type",
    "quantity",
    "constraints",
    "allocations",
    "status",
    "epoch",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["time", "money", "people", "infra", "attention", "other"]
    },
    "label": { "type": "string" },
    "quantity": {
      "type": "object",
      "required": ["total", "allocated", "unit"],
      "properties": {
        "total": { "type": "number" },
        "allocated": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "type"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["hard", "soft"] }
        },
        "additionalProperties": false
      }
    },
    "allocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "amount", "unit", "epoch"],
        "properties": {
          "decision_id": { "type": "string" },
          "amount": { "type": "number" },
          "unit": { "type": "string" },
          "epoch": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "exhausted", "frozen", "retired"]
    },
    "epoch": { "type": "integer" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
