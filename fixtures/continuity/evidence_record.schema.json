{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "UGR/EIT-1.md#EvidenceRecord/v1.0.0",
  "title": "EvidenceRecord",
  "description": "Atomic unit of justification for lawful substrate decisions",
  "type": "object",
  "required": [
    "evidence_id",
    "evidence_hash",
    "evidence_type",
    "source_lineage",
    "source_epoch",
    "validation_method",
    "confidence",
    "dependencies",
    "trace_links",
    "canonical_hash"
  ],
  "properties": {
    "evidence_id": { "type": "string" },
    "evidence_hash": { "type": "string" },
    "evidence_type": {
      "type": "string",
      "enum": ["observation", "simulation", "derivation", "testimony", "import"]
    },
    "source_lineage": { "type": "string" },
    "source_epoch": { "type": "integer" },
    "validation_method": { "type": "string" },
    "confidence": { "type": "number" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "trace_links": { "type": "array", "items": { "type": "string" } },
    "canonical_hash": { "type": "string" }
  }
}
