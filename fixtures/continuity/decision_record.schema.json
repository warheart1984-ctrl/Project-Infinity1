{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "UGR/RTC-1.md#DecisionObject/v0.1.0",
  "title": "DecisionObject",
  "type": "object",
  "required": [
    "id",
    "actor_id",
    "identity_id",
    "intent",
    "type",
    "evidence_refs",
    "risk_profile",
    "governance_basis",
    "resource_plan",
    "status",
    "epoch",
    "tags",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "actor_id": { "type": "string" },
    "identity_id": { "type": "string" },
    "intent": { "type": "string" },
    "type": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "risk_profile": { "type": "object" },
    "governance_basis": { "type": "object" },
    "resource_plan": { "type": "object" },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "executing", "executed", "rejected", "cancelled"]
    },
    "epoch": { "type": "integer" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": false
}
