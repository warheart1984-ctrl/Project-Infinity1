# Copy to your ngrok config after adding authtoken:
#   ngrok config add-authtoken YOUR_TOKEN
#   copy scripts\ngrok\ngrok-nova.yml.example %LOCALAPPDATA%\ngrok\ngrok.yml
#
# Reserved dev domain (from dashboard):
#   scoreless-calzone-plant.ngrok-free.dev
#
# Run once (foreground):
#   ngrok http 8080 --url=scoreless-calzone-plant.ngrok-free.dev
#
# Or install as Windows background service:
#   ngrok service install --config %LOCALAPPDATA%\ngrok\ngrok.yml
#   ngrok service start
#
# Cursor Override OpenAI Base URL:
#   https://scoreless-calzone-plant.ngrok-free.dev/v1

version: "3"

agent:
  authtoken: YOUR_AUTHTOKEN_HERE

endpoints:
  - name: lawful-nova
    url: scoreless-calzone-plant.ngrok-free.dev
    upstream:
      url: http://127.0.0.1:8080
