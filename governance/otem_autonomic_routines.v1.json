{
  "otem_autonomic_routines_version": "otem_autonomic_routines.v1",
  "enabled_env": "AAIS_OTEM_AUTONOMIC_ENABLED",
  "arc_ceiling_env": "AAIS_OTEM_AUTONOMIC_ARC_CEILING",
  "default_arc_ceiling": "ARC-1",
  "routines": [
    {
      "routine_id": "health_poll",
      "display_name": "Somatic health poll",
      "arc_class": "ARC-0",
      "handler": "operator_somatic_health",
      "blast_radius": "read_only"
    },
    {
      "routine_id": "doctor_snapshot",
      "display_name": "AAIS doctor snapshot",
      "arc_class": "ARC-0",
      "handler": "aais_doctor",
      "blast_radius": "read_only"
    },
    {
      "routine_id": "dry_run_chain",
      "display_name": "Dry-run workflow chain",
      "arc_class": "ARC-1",
      "handler": "workflow_chain_dry_run",
      "blast_radius": "local_idempotent"
    },
    {
      "routine_id": "ledger_digest",
      "display_name": "Operator ledger digest",
      "arc_class": "ARC-0",
      "handler": "ledger_digest",
      "blast_radius": "read_only"
    }
  ],
  "forbidden_autonomic": [
    "repo_patch_apply",
    "forge_mutation",
    "immune_quarantine",
    "biometric_storage"
  ]
}
