{
  "name": "The Six Wards of Jarvis",
  "version": "1.0.0",
  "doctrine": {
    "lines": [
      "Shield the core.",
      "Protect stability.",
      "Guard the boundaries.",
      "Ward against corruption.",
      "See the true state.",
      "Grow weary before collapse."
    ],
    "purpose": "Stabilize Jarvis at the core so adaptive and evolving systems operate only inside approved modular zones."
  },
  "zones": {
    "protected": [
      "core_identity",
      "permanent_mission",
      "protected_voice",
      "foundational_rules",
      "irreversible_guardrail_doctrine"
    ],
    "adaptive": [
      "mode_pipelines",
      "workspace_runners",
      "module_policy",
      "tool_result_shaping",
      "knowledge_routing",
      "provider_payload_formatting"
    ],
    "experimental": [
      "proposal_generation",
      "scoring_loops",
      "safe_configuration_experiments",
      "bounded_optimization"
    ]
  },
  "wards": [
    {
      "name": "SHIELD",
      "purpose": "Protect the core identity.",
      "blocks": [
        "core identity mutation",
        "unapproved protected-zone edits",
        "hidden replacement of core logic"
      ]
    },
    {
      "name": "PROTECT",
      "purpose": "Preserve structural stability.",
      "blocks": [
        "unstable merges",
        "broken module contracts",
        "nondeterministic assembly"
      ]
    },
    {
      "name": "GUARD",
      "purpose": "Defend subsystem boundaries.",
      "blocks": [
        "direct provider mutation",
        "hidden subsystem behavior",
        "boundary breaches"
      ]
    },
    {
      "name": "WARD",
      "purpose": "Prevent contamination.",
      "blocks": [
        "context contamination",
        "stale context promotion",
        "tool failures becoming authoritative"
      ]
    },
    {
      "name": "SEE",
      "purpose": "Keep the system inspectable.",
      "requires": [
        "trace_available",
        "provider_preview_available",
        "protocol_view_available"
      ]
    },
    {
      "name": "WEARY",
      "purpose": "Detect fatigue and loops before collapse.",
      "signals": [
        "high repetition score",
        "deep recursion",
        "degraded reasoning",
        "overload"
      ]
    }
  ],
  "thresholds": {
    "repetition_warn": 0.65,
    "repetition_fail": 0.8,
    "recursion_warn": 2,
    "recursion_fail": 4
  }
}