{
  "manifest_version": "repo_hygiene_manifest.v1",
  "authority": "docs/subsystems/repo_steward/RULE_SET.md",
  "rules": [
    {
      "id": "hygiene.forbidden_root_name",
      "severity": "error",
      "check": "forbidden_root_names",
      "remediation": "Delete locally or never commit; see ROOT_STRUCTURE_AUDIT section 3"
    },
    {
      "id": "hygiene.forbidden_root_glob",
      "severity": "warn",
      "check": "forbidden_root_globs",
      "remediation": "Move off repo root or delete locally"
    },
    {
      "id": "hygiene.poison_dir",
      "severity": "error",
      "check": "poison_dir_markers",
      "remediation": "Run python scripts/repo/remove-poison-dir.py on Windows; delete accidental bundle mirror"
    },
    {
      "id": "hygiene.forbidden_tracked",
      "severity": "error",
      "check": "forbidden_tracked_prefixes",
      "remediation": "git rm --cached and fix source"
    },
    {
      "id": "hygiene.local_work_dir",
      "severity": "warn",
      "check": "local_work_dirs",
      "remediation": "Safe to delete when not in active use"
    },
    {
      "id": "hygiene.stale_payload_runtime",
      "severity": "warn",
      "check": "stale_payload_runtime",
      "remediation": "Delete payload cog_runtime tree; re-run stage-nova-cortex-into-payload.sh"
    },
    {
      "id": "hygiene.stray_root_argv",
      "severity": "warn",
      "check": "forbidden_root_argv_globs",
      "remediation": "Delete stray argv files per .gitignore"
    }
  ],
  "forbidden_root_names": [
    "AAIS-main",
    "Aris--main",
    "Project-Infinity-main",
    "aris",
    "aris_launcher.py",
    "ARIS.spec",
    "start_jarvis.py"
  ],
  "forbidden_root_globs": [
    "*.iso",
    "*.iso.sha256",
    "*.img",
    "ProjectInfinity_UL_Documentation.pdf",
    "project_blueprints_infinity.html",
    "Aris--main.zip"
  ],
  "forbidden_root_argv_globs": [
    "--*",
    "bash",
    "python3"
  ],
  "forbidden_tracked_prefixes": [
    "AAIS-main/",
    "Aris--main/",
    "Project-Infinity-main/",
    "aris/",
    "opt/cogos/"
  ],
  "poison_dir_markers": [
    "opt/cogos",
    ".synthetic-mind-bundle-build"
  ],
  "allowed_bundle_roots": [
    "wolf-cog-os/artifacts/synthetic-mind-bundle",
    "wolf-cog-os/payload"
  ],
  "local_work_dirs": [
    ".cogos-live-safe-work",
    ".cogos-master-boot-work",
    ".ground-up-work",
    ".tmp-matrix-sweep",
    "_tmp_iso_check",
    "metal-iso-extract",
    "ci-artifacts",
    "release"
  ],
  "stale_payload_runtime": "wolf-cog-os/payload/opt/cogos/runtime/src/cog_runtime",
  "canonical_cog_runtime": "src/cog_runtime"
}
