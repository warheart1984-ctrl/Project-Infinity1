# AAIS Docker Compose Environment Variables

# Application
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# Database
POSTGRES_USER=aais
POSTGRES_PASSWORD=aais_password
POSTGRES_DB=aais_db
DATABASE_URL=postgresql://aais:aais_password@db:5432/aais_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
RATE_LIMIT=60

# API
REACT_APP_API_URL=http://localhost:5000

# Device
DEVICE=cpu
