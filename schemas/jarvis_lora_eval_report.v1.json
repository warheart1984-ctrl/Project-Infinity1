{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jarvis_lora_eval_report.v1",
  "title": "Jarvis LoRA Eval Report v1",
  "description": "Base-vs-adapter evaluation report with acceptance verdict.",
  "type": "object",
  "required": [
    "jarvis_lora_eval_report_version",
    "run_id",
    "generated_at",
    "adapter_metadata_path",
    "acceptance_profile",
    "base",
    "adapter",
    "deltas",
    "acceptance"
  ],
  "properties": {
    "jarvis_lora_eval_report_version": {
      "const": "jarvis_lora_eval_report.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "adapter_metadata_path": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_profile": {
      "type": "string",
      "minLength": 1
    },
    "mock_model": {
      "type": "boolean"
    },
    "base": {
      "$ref": "#/$defs/mode_aggregates"
    },
    "adapter": {
      "$ref": "#/$defs/mode_aggregates"
    },
    "deltas": {
      "type": "object",
      "additionalProperties": true
    },
    "comparisons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comparison"
      }
    },
    "acceptance": {
      "$ref": "#/$defs/acceptance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "mode_aggregates": {
      "type": "object",
      "properties": {
        "fast": { "type": "object" },
        "think": { "type": "object" }
      },
      "additionalProperties": true
    },
    "comparison": {
      "type": "object",
      "required": ["prompt_id", "response_mode", "base_status_code", "adapter_status_code"],
      "properties": {
        "prompt_id": { "type": "string" },
        "response_mode": { "type": "string" },
        "base_status_code": { "type": "integer" },
        "adapter_status_code": { "type": "integer" },
        "base_preview": { "type": "string" },
        "adapter_preview": { "type": "string" }
      },
      "additionalProperties": true
    },
    "acceptance": {
      "type": "object",
      "required": ["passed", "failures"],
      "properties": {
        "passed": { "type": "boolean" },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
