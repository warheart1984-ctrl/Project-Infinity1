{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "temporal_replay_event.v1",
  "title": "Temporal Replay Event v1",
  "type": "object",
  "required": [
    "event_id",
    "subject_type",
    "subject_id",
    "timestamp_utc",
    "sequence",
    "kind",
    "summary",
    "emitter"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "subject_type": {
      "enum": [
        "mission",
        "session",
        "workflow_run",
        "ugr_trace",
        "slingshot_case",
        "jarvis_run",
        "operator_session"
      ]
    },
    "subject_id": { "type": "string", "minLength": 1 },
    "timestamp_utc": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 0 },
    "kind": {
      "enum": [
        "mission_receipt",
        "pipeline_turn",
        "continuity_witness",
        "intent_agency",
        "platform_job",
        "operator_decision"
      ]
    },
    "summary": { "type": "string", "maxLength": 500 },
    "emitter": {
      "type": "object",
      "properties": {
        "subsystem_id": { "type": "string" },
        "module": { "type": "string" },
        "genome_ref": { "type": "string" }
      }
    },
    "law_context": { "type": "object" },
    "boundary": { "type": "object" },
    "causal_parents": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 8
    },
    "payload_ref": { "type": "object" },
    "receipt_ref": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
