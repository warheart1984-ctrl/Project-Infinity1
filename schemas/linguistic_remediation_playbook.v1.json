{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_remediation_playbook.v1",
  "title": "Linguistic Remediation Playbook v1",
  "type": "object",
  "required": [
    "linguistic_remediation_playbook_version",
    "gene",
    "drift_band",
    "actions"
  ],
  "properties": {
    "linguistic_remediation_playbook_version": {
      "const": "linguistic_remediation_playbook.v1"
    },
    "gene": { "type": "string" },
    "drift_band": { "enum": ["low", "medium", "high"] },
    "drift_risk": { "type": "integer" },
    "generated_at": { "type": "string" },
    "signals": { "type": "object" },
    "actions": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
