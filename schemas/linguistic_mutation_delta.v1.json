{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_mutation_delta.v1",
  "title": "Linguistic Mutation Delta v1",
  "type": "object",
  "required": [
    "mutation_kind",
    "gene",
    "backward_compatible",
    "before",
    "after",
    "bump_linguistic_version"
  ],
  "properties": {
    "mutation_kind": { "const": "linguistic_layer" },
    "gene": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "backward_compatible": { "const": true },
    "before": { "$ref": "#/$defs/linguistic_fields" },
    "after": { "$ref": "#/$defs/linguistic_fields" },
    "bump_linguistic_version": {
      "type": "string",
      "minLength": 1
    },
    "touch_source_header": { "type": "boolean", "default": false },
    "alias_override_justification": {
      "type": "string",
      "minLength": 1
    },
    "cascade_ack": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "description": "Child genes acknowledged when cascade policy requires it."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "linguistic_fields": {
      "type": "object",
      "properties": {
        "mythic_label": { "type": "string" },
        "engineering_class": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
