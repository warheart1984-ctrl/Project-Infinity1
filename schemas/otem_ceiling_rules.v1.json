{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aais.otem_ceiling.v1",
  "title": "OTEM Ceiling Rules v1",
  "type": "object",
  "required": [
    "ceiling_version",
    "authority_band",
    "numeric_level",
    "ceiling_active",
    "constitutional_law",
    "mutable_policy_refs",
    "operator_unavailable_policy",
    "pipeline_state"
  ],
  "properties": {
    "ceiling_version": { "const": "aais.otem_ceiling.v1" },
    "authority_band": {
      "enum": ["autonomous", "governed", "containment", "sovereign"]
    },
    "numeric_level": { "type": "integer", "minimum": 1, "maximum": 20 },
    "ceiling_active": { "type": "boolean" },
    "containment_mode": { "type": "boolean" },
    "activation_triggers": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 16
    },
    "constitutional_law": {
      "type": "array",
      "items": {
        "enum": [
          "human_principal_root",
          "fail_closed",
          "no_self_delegation_of_ceiling_authority",
          "auditability_odl_binding",
          "defensive_only",
          "monotonic_authority_constraints"
        ]
      }
    },
    "mutable_policy_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operator_unavailable_policy": {
      "type": "object",
      "required": ["timeout_minutes", "fallback"],
      "properties": {
        "timeout_minutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "fallback": { "enum": ["quarantine_archive"] }
      }
    },
    "pipeline_state": {
      "enum": ["idle", "diagnostic", "preview", "awaiting_decision", "closing_ledger"]
    },
    "diagnostic_bundle_id": { "type": ["string", "null"] },
    "preview_fingerprint": { "type": ["string", "null"] },
    "pending_decision": { "type": ["string", "null"] },
    "odl_root_id": { "type": ["string", "null"] },
    "invocation_count": { "type": "integer", "minimum": 0 },
    "last_trigger_at": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
