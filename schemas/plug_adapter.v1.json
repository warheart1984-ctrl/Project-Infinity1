{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plug_adapter.v1",
  "type": "object",
  "required": ["plug_adapter_version", "plug_id", "display_name", "plug_class", "authority_level", "enabled", "cisiv_stage"],
  "properties": {
    "plug_adapter_version": {"const": "plug_adapter.v1"},
    "plug_id": {"type": "string", "maxLength": 128},
    "display_name": {"type": "string", "maxLength": 256},
    "plug_class": {"enum": ["mcp", "cursor_skill", "hf_agent_skill", "native_capability", "workflow"]},
    "authority_level": {"enum": ["observe", "assist", "execute", "admin"]},
    "enabled": {"type": "boolean"},
    "cisiv_stage": {"type": "string"},
    "library_id": {"type": "string"},
    "pattern": {"type": "string"},
    "provenance": {"type": "object"}
  },
  "additionalProperties": true
}
