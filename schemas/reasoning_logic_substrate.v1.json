{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-infi.local/schemas/reasoning_logic_substrate.v1.json",
  "title": "Reasoning & Logic Substrate v1",
  "description": "ReasoningGraph and RLSVerdict schemas for the epistemic firewall.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ReasoningGraph" },
    { "$ref": "#/$defs/RLSVerdict" }
  ],
  "$defs": {
    "ReasoningGraph": {
      "type": "object",
      "required": ["id", "version", "timestamp", "source", "nodes", "edges", "conclusion_id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "const": "1.0" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": {
          "type": "string",
          "enum": ["jarvis", "external", "otem_justification"]
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ReasoningNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/ReasoningEdge" }
        },
        "conclusion_id": { "type": "string", "minLength": 1 },
        "proposed_action": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "intent": { "type": "string" },
            "otem_level": { "type": "integer", "minimum": 1, "maximum": 20 },
            "action_class": { "type": "string" }
          }
        }
      }
    },
    "ReasoningNode": {
      "type": "object",
      "required": ["id", "kind", "text"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["premise", "inference", "conclusion"]
        },
        "text": { "type": "string" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ReasoningEdge": {
      "type": "object",
      "required": ["from", "to", "relation"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "relation": {
          "type": "string",
          "enum": ["supports", "derives"]
        }
      }
    },
    "RLSViolation": {
      "type": "object",
      "required": ["code", "severity", "detail"],
      "additionalProperties": true,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "missing_evidence",
            "orphan_conclusion",
            "circular_reasoning",
            "self_justifying_loop",
            "unsupported_leap",
            "constitutional_conflict",
            "monotonic_falsity_violation",
            "speculative_at_ceiling",
            "missing_verdict"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "node_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detail": { "type": "string" },
        "invariant_id": { "type": "string" }
      }
    },
    "RLSVerdict": {
      "type": "object",
      "required": [
        "verdict",
        "confidence_band",
        "violations",
        "mode",
        "graph_id",
        "otem_level"
      ],
      "additionalProperties": true,
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["admit", "downgrade", "reject"]
        },
        "confidence_band": {
          "type": "string",
          "enum": ["denied", "hypothetical", "asserted", "proven"]
        },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/RLSViolation" }
        },
        "mode": {
          "type": "string",
          "enum": ["lightweight", "governed", "paranoid", "hyper_strict"]
        },
        "graph_id": { "type": "string" },
        "otem_level": { "type": "integer", "minimum": 1, "maximum": 20 },
        "quarantine_id": { "type": "string" },
        "cannot_justify_escalation": { "type": "boolean" },
        "evaluated_at": { "type": "string", "format": "date-time" }
      }
    },
    "RLSMode": {
      "type": "string",
      "enum": ["lightweight", "governed", "paranoid", "hyper_strict"]
    }
  }
}
