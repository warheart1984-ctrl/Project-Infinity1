{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jarvis_lora_promotion_record.v1",
  "title": "Jarvis LoRA Promotion Record v1",
  "description": "Operator promotion record written into adapter metadata on promote.",
  "type": "object",
  "required": [
    "jarvis_lora_promotion_record_version",
    "promoted_at",
    "promoted_by",
    "promotion_env"
  ],
  "properties": {
    "jarvis_lora_promotion_record_version": {
      "const": "jarvis_lora_promotion_record.v1"
    },
    "promoted_at": {
      "type": "string",
      "minLength": 1
    },
    "promoted_by": {
      "type": "string",
      "minLength": 1
    },
    "promotion_env": {
      "type": "object",
      "required": [
        "AAIS_TEXT_MODEL_NAME",
        "AAIS_ENABLE_TEXT_ADAPTERS",
        "AAIS_TEXT_ADAPTER_PATH"
      ],
      "properties": {
        "AAIS_TEXT_MODEL_NAME": { "type": "string", "minLength": 1 },
        "AAIS_ENABLE_TEXT_ADAPTERS": { "type": "string", "minLength": 1 },
        "AAIS_TEXT_ADAPTER_PATH": { "type": "string", "minLength": 1 },
        "AAIS_TEXT_ADAPTER_FAST_PATH": { "type": "string" },
        "AAIS_TEXT_ADAPTER_THINK_PATH": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
