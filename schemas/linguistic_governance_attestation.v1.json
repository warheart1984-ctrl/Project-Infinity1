{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_governance_attestation.v1",
  "title": "Linguistic Governance Attestation v1",
  "type": "object",
  "required": [
    "linguistic_governance_attestation_version",
    "generated_at",
    "closed_loop_score",
    "registry_summary",
    "recommendations"
  ],
  "properties": {
    "linguistic_governance_attestation_version": {
      "const": "linguistic_governance_attestation.v1"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "closed_loop_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "policy_mode": { "enum": ["observe", "enforce"] },
    "registry_summary": { "type": "object" },
    "forecast_summary": { "type": "object" },
    "calibration_summary": { "type": "object" },
    "queue_summary": { "type": "object" },
    "work_order_summary": { "type": "object" },
    "full_cycle_summary": { "type": "object" },
    "recommendations": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
