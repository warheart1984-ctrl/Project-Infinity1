{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_forecast_calibration.v1",
  "title": "Linguistic Forecast Calibration v1",
  "type": "object",
  "required": [
    "linguistic_forecast_calibration_version",
    "generated_at",
    "forecast_generated_at",
    "metrics",
    "gene_records"
  ],
  "properties": {
    "linguistic_forecast_calibration_version": {
      "const": "linguistic_forecast_calibration.v1"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "forecast_generated_at": { "type": "string", "format": "date-time" },
    "forecast_cycle_id": { "type": "string" },
    "metrics": {
      "type": "object",
      "properties": {
        "gene_count": { "type": "integer" },
        "band_hit_rate": { "type": "number" },
        "false_alarm_rate": { "type": "number" },
        "miss_rate": { "type": "number" },
        "stable_rate": { "type": "number" },
        "mean_abs_risk_error": { "type": "number" }
      },
      "additionalProperties": true
    },
    "signal_attribution": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "false_alarm_count": { "type": "integer" },
          "miss_count": { "type": "integer" },
          "hit_count": { "type": "integer" }
        }
      }
    },
    "weight_adjustments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal", "direction", "reason"],
        "properties": {
          "signal": { "type": "string" },
          "direction": { "enum": ["increase", "decrease", "hold"] },
          "suggested_delta": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    },
    "recommended_weights": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "gene_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gene", "predicted_band", "actual_band", "band_outcome"],
        "properties": {
          "gene": { "type": "string" },
          "predicted_band": { "enum": ["low", "medium", "high"] },
          "actual_band": { "enum": ["low", "medium", "high"] },
          "predicted_risk_30d": { "type": "integer" },
          "actual_risk": { "type": "integer" },
          "risk_delta": { "type": "integer" },
          "band_outcome": {
            "enum": ["hit", "false_alarm", "miss", "stable"]
          },
          "lead_time_days": { "type": "integer" },
          "lead_time_accuracy": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
