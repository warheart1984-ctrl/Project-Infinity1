{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operator_cognition_coherence_fabric.v1.1",
  "title": "Operator Cognition Coherence Fabric v1.1",
  "type": "object",
  "required": [
    "operator_cognition_coherence_fabric_version",
    "authority_lane",
    "resolved_lane",
    "fabric_genes_aligned",
    "cisiv_stage",
    "claim_label",
    "read_only"
  ],
  "properties": {
    "operator_cognition_coherence_fabric_version": {
      "const": "operator_cognition_coherence_fabric.v1.1"
    },
    "authority_lane": { "type": "string", "minLength": 1 },
    "resolved_lane": { "type": "string", "minLength": 1 },
    "envelope_governance_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["envelope_id", "governance_mode"],
        "properties": {
          "envelope_id": { "type": "string" },
          "governance_mode": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "runtime_posture": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["organ_id", "stage", "claim_label"],
        "properties": {
          "organ_id": { "type": "string" },
          "stage": { "type": "string" },
          "claim_label": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "fabric_genes_aligned": { "type": "boolean" },
    "profile_posture": { "type": "string" },
    "lane_awakened": { "type": "boolean" },
    "cisiv_stage": {
      "enum": ["concept", "identity", "structure", "implementation", "verification"]
    },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "read_only": { "type": "boolean" }
  },
  "additionalProperties": false
}
