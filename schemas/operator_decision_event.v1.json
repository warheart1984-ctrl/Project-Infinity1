{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operator_decision_event.v1",
  "title": "Operator Decision Event v1",
  "type": "object",
  "required": [
    "event_version",
    "decision_id",
    "recorded_at",
    "decision_kind",
    "decision",
    "reversibility",
    "summary",
    "claim_label",
    "cisiv_stage"
  ],
  "properties": {
    "event_version": { "const": "operator_decision_event.v1" },
    "decision_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string" },
    "decision_kind": {
      "enum": [
        "pipeline_turn",
        "otem_approval",
        "urg_receipt",
        "checkpoint_block",
        "plug_execution",
        "brain_decision"
      ]
    },
    "decision": {
      "enum": ["allow", "pending", "approve", "reject", "completed", "failed", "block", "defer"]
    },
    "reversibility": {
      "enum": ["undo_available", "cannot_undo", "not_applicable"]
    },
    "session_id": { "type": ["string", "null"] },
    "pipeline_id": { "type": ["string", "null"] },
    "approval_id": { "type": ["string", "null"] },
    "mission_id": { "type": ["string", "null"] },
    "tenant_id": { "type": ["string", "null"] },
    "causal_parents": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 8
    },
    "blast_radius": {
      "type": "object",
      "properties": {
        "impact_id": { "type": "string" },
        "affected_files": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 12
        },
        "risk_level": { "enum": ["low", "medium", "high"] },
        "integration_seams": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "kind": { "type": "string" }
            }
          },
          "maxItems": 8
        }
      }
    },
    "drift_context": {
      "type": "object",
      "properties": {
        "drift_band": {
          "enum": ["nominal", "watch", "drifting", "critical", "idle"]
        },
        "trajectory_status": { "type": "string" },
        "identity_distance": { "type": "number" },
        "pipeline_id": { "type": ["string", "null"] }
      }
    },
    "federation": {
      "type": "object",
      "properties": {
        "federation_digest": { "type": "string" },
        "grant_id": { "type": "string" },
        "counterparty_receipt_ref": {
          "type": "object",
          "properties": {
            "tenant_id": { "type": "string" },
            "mission_id": { "type": "string" },
            "grant_id": { "type": "string" }
          }
        }
      }
    },
    "summary": { "type": "string", "maxLength": 500 },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "cisiv_stage": {
      "enum": ["concept", "identity", "structure", "implementation", "verification"]
    },
    "row_hash": { "type": "string" },
    "prev_row_hash": { "type": "string" }
  }
}
