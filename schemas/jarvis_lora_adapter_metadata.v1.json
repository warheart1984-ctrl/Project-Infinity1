{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jarvis_lora_adapter_metadata.v1",
  "title": "Jarvis LoRA Adapter Metadata v1",
  "description": "Required metadata artifact written to final/adapter_metadata.json after training.",
  "type": "object",
  "required": [
    "jarvis_lora_adapter_metadata_version",
    "run_id",
    "created_at",
    "base_model",
    "dataset",
    "hyperparams",
    "output_dir",
    "promotion_status"
  ],
  "properties": {
    "jarvis_lora_adapter_metadata_version": {
      "const": "jarvis_lora_adapter_metadata.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "base_model": {
      "enum": ["Qwen/Qwen2.5-1.5B-Instruct"]
    },
    "dataset": {
      "$ref": "#/$defs/dataset"
    },
    "hyperparams": {
      "$ref": "#/$defs/hyperparams"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "dataset_checksum": {
      "type": "string",
      "minLength": 1
    },
    "git_commit": {
      "type": ["string", "null"]
    },
    "promotion_status": {
      "enum": ["draft", "eval_passed", "promoted"]
    },
    "eval_report_path": {
      "type": ["string", "null"]
    },
    "admission_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "promotion_record": {
      "$ref": "#/$defs/promotion_record"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dataset": {
      "type": "object",
      "required": ["path", "example_count", "sources"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "example_count": {
          "type": "integer",
          "minimum": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "enum": ["seed", "private", "external"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "admission_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "hyperparams": {
      "type": "object",
      "required": [
        "epochs",
        "learning_rate",
        "max_length",
        "lora_rank",
        "lora_alpha",
        "lora_dropout",
        "per_device_batch_size",
        "gradient_accumulation_steps",
        "use_4bit"
      ],
      "properties": {
        "epochs": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "learning_rate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_length": {
          "type": "integer",
          "minimum": 64
        },
        "lora_rank": {
          "type": "integer",
          "minimum": 1
        },
        "lora_alpha": {
          "type": "integer",
          "minimum": 1
        },
        "lora_dropout": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "per_device_batch_size": {
          "type": "integer",
          "minimum": 1
        },
        "gradient_accumulation_steps": {
          "type": "integer",
          "minimum": 1
        },
        "use_4bit": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "promotion_record": {
      "type": "object",
      "required": [
        "jarvis_lora_promotion_record_version",
        "promoted_at",
        "promoted_by",
        "promotion_env"
      ],
      "properties": {
        "jarvis_lora_promotion_record_version": {
          "const": "jarvis_lora_promotion_record.v1"
        },
        "promoted_at": { "type": "string", "minLength": 1 },
        "promoted_by": { "type": "string", "minLength": 1 },
        "promotion_env": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
