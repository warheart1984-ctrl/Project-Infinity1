{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_drift_forecast.v1",
  "title": "Linguistic Drift Forecast v1",
  "type": "object",
  "required": [
    "linguistic_drift_forecast_version",
    "generated_at",
    "horizon_days",
    "forecasts"
  ],
  "properties": {
    "linguistic_drift_forecast_version": {
      "const": "linguistic_drift_forecast.v1"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "horizon_days": { "type": "integer", "minimum": 1 },
    "ecosystem_trend": { "type": "number" },
    "forecasts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gene",
          "current_risk",
          "current_band",
          "predicted_risk_30d",
          "predicted_band",
          "lead_time_days",
          "signals",
          "drivers"
        ],
        "properties": {
          "gene": { "type": "string" },
          "current_risk": { "type": "integer", "minimum": 0, "maximum": 100 },
          "current_band": { "enum": ["low", "medium", "high"] },
          "predicted_risk_30d": { "type": "integer", "minimum": 0, "maximum": 100 },
          "predicted_band": { "enum": ["low", "medium", "high"] },
          "lead_time_days": { "type": "integer", "minimum": 0 },
          "signals": { "type": "object" },
          "drivers": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
