{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_preemptive_playbook.v1",
  "title": "Linguistic Preemptive Playbook v1",
  "type": "object",
  "required": [
    "linguistic_preemptive_playbook_version",
    "gene",
    "predicted_band",
    "predicted_risk_30d",
    "generated_at",
    "actions"
  ],
  "properties": {
    "linguistic_preemptive_playbook_version": {
      "const": "linguistic_preemptive_playbook.v1"
    },
    "gene": { "type": "string" },
    "current_band": { "enum": ["low", "medium", "high"] },
    "predicted_band": { "enum": ["low", "medium", "high"] },
    "predicted_risk_30d": { "type": "integer", "minimum": 0, "maximum": 100 },
    "lead_time_days": { "type": "integer", "minimum": 0 },
    "generated_at": { "type": "string", "format": "date-time" },
    "drivers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "command": { "type": "string" },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
