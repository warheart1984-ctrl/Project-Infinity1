{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "continuity_governance.v1",
  "title": "Continuity Governance Objects v1",
  "description": "Proof, Continuity-Validated Reputation, ContinuityTrace v1 projection, and ContinuitySubstrate objects binding POD, CCS, and ContinuityTrace under UGR.",
  "oneOf": [
    { "$ref": "#/$defs/Proof" },
    { "$ref": "#/$defs/ContinuityValidatedReputation" },
    { "$ref": "#/$defs/ContinuitySubstrate" },
    { "$ref": "#/$defs/PODDecision" },
    { "$ref": "#/$defs/ContinuityTraceV1" },
    { "$ref": "#/$defs/ContinuityMetrics" },
    { "$ref": "#/$defs/ContinuityGovernanceReceipt" }
  ],
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "Timestamp": { "type": "string", "minLength": 1 },
    "ProofStatus": {
      "type": "string",
      "enum": ["PROVEN", "REVOKED", "PENDING"]
    },
    "Proof": {
      "type": "object",
      "required": [
        "proof_id",
        "subject_ref",
        "continuity_trace_ref",
        "law_surfaces",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "proof_id": { "type": "string", "minLength": 1 },
        "subject_ref": { "type": "string", "minLength": 1 },
        "continuity_trace_ref": { "type": "string", "minLength": 1 },
        "law_surfaces": { "$ref": "#/$defs/StringArray" },
        "status": { "$ref": "#/$defs/ProofStatus" },
        "created_at": { "$ref": "#/$defs/Timestamp" },
        "updated_at": { "$ref": "#/$defs/Timestamp" },
        "continuity_invariants": { "type": "object" },
        "replay_fingerprint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ReputationMetrics": {
      "type": "object",
      "required": [
        "proofs_count",
        "proofs_replay_stable",
        "revoked_proofs",
        "continuity_score_avg",
        "evidence_integrity_avg",
        "authority_chain_strength_avg"
      ],
      "properties": {
        "proofs_count": { "type": "integer", "minimum": 0 },
        "proofs_replay_stable": { "type": "integer", "minimum": 0 },
        "revoked_proofs": { "type": "integer", "minimum": 0 },
        "continuity_score_avg": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_integrity_avg": { "type": "number", "minimum": 0, "maximum": 1 },
        "authority_chain_strength_avg": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "ReputationWeights": {
      "type": "object",
      "description": "Governance-tunable α,β,γ,δ,ε weights for derived_score.",
      "properties": {
        "alpha": { "type": "number", "minimum": 0, "maximum": 1 },
        "beta": { "type": "number", "minimum": 0, "maximum": 1 },
        "gamma": { "type": "number", "minimum": 0, "maximum": 1 },
        "delta": { "type": "number", "minimum": 0, "maximum": 1 },
        "epsilon": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "ContinuityValidatedReputation": {
      "type": "object",
      "required": [
        "cvr_id",
        "subject_id",
        "scope",
        "basis",
        "metrics",
        "derived_score",
        "law_surfaces",
        "last_recomputed_at"
      ],
      "properties": {
        "cvr_id": { "type": "string", "minLength": 1 },
        "subject_id": { "type": "string", "minLength": 1 },
        "scope": { "type": "object" },
        "basis": {
          "type": "object",
          "required": ["proofs", "traces"],
          "properties": {
            "proofs": { "$ref": "#/$defs/StringArray" },
            "traces": { "$ref": "#/$defs/StringArray" }
          },
          "additionalProperties": false
        },
        "metrics": { "$ref": "#/$defs/ReputationMetrics" },
        "derived_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "law_surfaces": { "$ref": "#/$defs/StringArray" },
        "last_recomputed_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "ContinuityTraceV1": {
      "type": "object",
      "description": "Formal v1 projection of a CCS ContinuityTrace — proof is a trace, not a label.",
      "required": [
        "trace_id",
        "subject_ref",
        "identity_refs",
        "event_refs",
        "evaluation_refs",
        "evidence_refs",
        "metrics_ref",
        "law_surfaces",
        "trace_hash"
      ],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "subject_ref": { "type": "string", "minLength": 1 },
        "identity_refs": { "$ref": "#/$defs/StringArray" },
        "event_refs": { "$ref": "#/$defs/StringArray" },
        "evaluation_refs": { "$ref": "#/$defs/StringArray" },
        "evidence_refs": { "$ref": "#/$defs/StringArray" },
        "metrics_ref": { "type": "string" },
        "law_surfaces": { "$ref": "#/$defs/StringArray" },
        "trace_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64,
          "pattern": "^[a-f0-9]{64}$"
        },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "ContinuityMetrics": {
      "type": "object",
      "description": "Per-trace continuity metrics referenced by ContinuityTrace v1.",
      "required": ["metrics_id", "continuity_score"],
      "properties": {
        "metrics_id": { "type": "string", "minLength": 1 },
        "continuity_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "lineage_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "authority_chain_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_integrity_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "drift_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "preservation_risk": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "ContinuityGovernanceReceipt": {
      "type": "object",
      "description": "Nova lawful-turn continuity governance bundle embedded in signed receipts.",
      "required": ["cvr"],
      "properties": {
        "proof": { "$ref": "#/$defs/Proof" },
        "cvr": { "$ref": "#/$defs/ContinuityValidatedReputation" },
        "continuity_trace": { "$ref": "#/$defs/ContinuityTraceV1" },
        "continuity_metrics": { "$ref": "#/$defs/ContinuityMetrics" }
      },
      "additionalProperties": false
    },
    "ContinuitySubstrate": {
      "type": "object",
      "required": ["substrate_id", "pod_layer", "ccs_layer", "trace_layer", "invariants"],
      "properties": {
        "substrate_id": { "type": "string", "minLength": 1 },
        "pod_layer": {
          "type": "object",
          "properties": {
            "decisions": { "$ref": "#/$defs/StringArray" }
          },
          "additionalProperties": false
        },
        "ccs_layer": {
          "type": "object",
          "properties": {
            "identities": { "$ref": "#/$defs/StringArray" },
            "events": { "$ref": "#/$defs/StringArray" },
            "evaluations": { "$ref": "#/$defs/StringArray" },
            "evidence": { "$ref": "#/$defs/StringArray" }
          },
          "additionalProperties": false
        },
        "trace_layer": {
          "type": "object",
          "properties": {
            "traces": { "$ref": "#/$defs/StringArray" }
          },
          "additionalProperties": false
        },
        "invariants": { "$ref": "#/$defs/StringArray" }
      },
      "additionalProperties": false
    },
    "PODDecision": {
      "type": "object",
      "required": ["decision_id", "actor_id", "subject_ref"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "actor_id": { "type": "string", "minLength": 1 },
        "subject_ref": { "type": "string", "minLength": 1 },
        "law_surfaces": { "$ref": "#/$defs/StringArray" },
        "created_at": { "$ref": "#/$defs/Timestamp" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
