{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linguistic_snapshot.v1",
  "title": "Linguistic Snapshot v1",
  "description": "Checkpoint of mythic and engineering linguistic layers for a subsystem gene.",
  "type": "object",
  "required": [
    "linguistic_snapshot_version",
    "gene",
    "captured_at",
    "capture_source",
    "layers",
    "fingerprints"
  ],
  "properties": {
    "linguistic_snapshot_version": { "const": "linguistic_snapshot.v1" },
    "gene": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "capture_source": {
      "type": "string",
      "minLength": 1
    },
    "genome_stage": {
      "type": "string",
      "enum": ["concept", "prototype", "mvp", "governed", "deprecated", "retired"]
    },
    "layers": { "$ref": "#/$defs/layers" },
    "fingerprints": { "$ref": "#/$defs/fingerprints" }
  },
  "additionalProperties": false,
  "$defs": {
    "layers": {
      "type": "object",
      "required": ["genome"],
      "properties": {
        "genome": { "$ref": "#/$defs/genome_layer" },
        "source": { "$ref": "#/$defs/source_layer" },
        "docs": { "$ref": "#/$defs/docs_layer" }
      },
      "additionalProperties": false
    },
    "genome_layer": {
      "type": "object",
      "properties": {
        "engineering_class": { "type": "string" },
        "mythic_label": { "type": "string" },
        "linguistic_version": { "type": "string" },
        "display_name": { "type": "string" },
        "gene": { "type": "string" },
        "module_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "source_layer": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "header": { "type": "object" },
        "symbols": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": false
    },
    "docs_layer": {
      "type": "object",
      "properties": {
        "concept_spec": { "type": "object" },
        "active_doc": { "type": "object" }
      },
      "additionalProperties": false
    },
    "fingerprints": {
      "type": "object",
      "required": ["mythic", "engineering"],
      "properties": {
        "mythic": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "engineering": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "combined": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}
