{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urg_mission_receipt.v1",
  "title": "URG MissionReceipt v1.2",
  "type": "object",
  "required": [
    "schema_version",
    "urg_version",
    "invariant_version",
    "cloud_identity_hash",
    "boundary_digest",
    "mission_id",
    "goal_hash",
    "organs",
    "invariant_digest",
    "ledger_root",
    "operator_sig",
    "outcome",
    "receipt_sig",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.2"
    },
    "urg_version": {
      "type": "string"
    },
    "invariant_version": {
      "type": "string"
    },
    "cloud_identity_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "boundary_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mission_id": {
      "type": "string",
      "format": "uuid"
    },
    "mission_slug": {
      "type": "string"
    },
    "goal_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "organs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["organ_id", "provider", "contract_version", "ceiling", "region_id", "rail"],
        "properties": {
          "organ_id": { "type": "string" },
          "provider": { "type": "string" },
          "contract_version": { "type": "string" },
          "ceiling": { "type": "string" },
          "region_id": { "type": "string" },
          "rail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "invariant_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "ledger_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "operator_sig": {
      "type": "object",
      "required": ["operator_id", "stamped_at", "operator_mac"],
      "properties": {
        "operator_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "aais_instance_id": { "type": "string" },
        "stamped_at": { "type": "integer" },
        "operator_mac": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "operator_key_id": { "type": "string" }
      }
    },
    "outcome": {
      "enum": ["completed", "failed", "vetoed"]
    },
    "failure_reason": {
      "enum": [
        "UNFULFILLABLE_CONSTRAINTS",
        "NO_ADMISSIBLE_ORGAN",
        "GATE_REJECTION",
        "OPERATOR_VETO",
        "RUNTIME_ERROR",
        "BUDGET_EXCEEDED"
      ]
    },
    "urg_key_id": {
      "type": "string"
    },
    "receipt_sig": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "receipt_algorithm": {
      "enum": ["hmac-sha256", "sha256-content-only"]
    },
    "issued_at": {
      "type": "integer"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "outcome": { "const": "completed" } },
        "required": ["outcome"]
      },
      "then": {},
      "else": {
        "required": ["failure_reason"]
      }
    }
  ],
  "additionalProperties": true
}
