{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subsystem_genome.v1",
  "title": "Subsystem Genome v1",
  "description": "Meta-schema defining the genetic structure of AAIS subsystem families (SSP Alt-4).",
  "type": "object",
  "required": [
    "subsystem_genome_version",
    "identity",
    "governance",
    "schema",
    "runtime",
    "proof",
    "lineage",
    "activation",
    "mutation"
  ],
  "properties": {
    "subsystem_genome_version": { "const": "subsystem_genome.v1" },
    "identity": { "$ref": "#/$defs/identity" },
    "governance": { "$ref": "#/$defs/governance" },
    "schema": { "$ref": "#/$defs/schema_ref" },
    "runtime": { "$ref": "#/$defs/runtime" },
    "proof": { "$ref": "#/$defs/proof" },
    "lineage": { "$ref": "#/$defs/lineage" },
    "activation": { "$ref": "#/$defs/activation" },
    "retirement": { "$ref": "#/$defs/retirement" },
    "mutation": { "$ref": "#/$defs/mutation" },
    "ssp": { "$ref": "#/$defs/ssp_links" }
  },
  "additionalProperties": false,
  "$defs": {
    "identity": {
      "type": "object",
      "required": ["gene", "version", "stage"],
      "properties": {
        "gene": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique subsystem gene name (snake_case)."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Semantic version or stage tag (e.g. 1.0.0-mvp)."
        },
        "stage": {
          "enum": ["concept", "prototype", "mvp", "governed", "deprecated", "retired"]
        },
        "display_name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["contracts", "invariants"],
      "properties": {
        "contracts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/invariant_entry" }
            ]
          }
        },
        "operator_lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/operator_lane" }
        },
        "contextual_gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextual_gate" }
        }
      },
      "additionalProperties": false
    },
    "invariant_entry": {
      "type": "object",
      "required": ["text", "maturity"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "maturity": {
          "enum": ["emergent", "stable", "constitutional"]
        }
      },
      "additionalProperties": false
    },
    "operator_lane": {
      "type": "object",
      "required": ["lane_id", "weight"],
      "properties": {
        "lane_id": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "contextual_gate": {
      "type": "object",
      "required": ["gate_id", "activate_on", "make_target"],
      "properties": {
        "gate_id": { "type": "string", "minLength": 1 },
        "activate_on": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "make_target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "schema_ref": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^schemas/[a-z0-9_]+\\.v1\\.json$|^triangulation/schemas/[a-z0-9_]+\\.v1\\.json$"
        },
        "frozen": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "runtime_surface_entry": {
      "type": "object",
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["module", "cli", "api", "ui", "tool", "gate", "package", "sandbox"]
        },
        "path": { "type": "string", "minLength": 1 },
        "isolated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["surface"],
      "properties": {
        "surface": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtime_surface_entry" }
        }
      },
      "additionalProperties": false
    },
    "proof": {
      "type": "object",
      "required": ["bundles", "posture"],
      "properties": {
        "bundles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "posture": {
          "enum": ["asserted", "prototype", "mvp", "governed"]
        },
        "target_bundles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Planned proof paths at concept stage (optional)."
        }
      },
      "additionalProperties": false
    },
    "lineage": {
      "type": "object",
      "required": ["parents", "children"],
      "properties": {
        "parents": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "children": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      },
      "additionalProperties": false
    },
    "activation": {
      "type": "object",
      "required": ["order"],
      "properties": {
        "order": { "type": "integer", "minimum": 0 },
        "batch_id": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "retirement": {
      "type": "object",
      "properties": {
        "path": {
          "type": ["string", "null"],
          "description": "Doc path to retirement record or null if not retired."
        },
        "successor_gene": { "type": "string" },
        "shim_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "mutation_entry": {
      "type": "object",
      "required": ["proposal_id", "status"],
      "properties": {
        "proposal_id": { "type": "string", "pattern": "^MP-[A-Z0-9-]+$" },
        "status": {
          "enum": ["proposed", "schema_delta", "tests_added", "proof_pending", "promoted", "reverted"]
        },
        "schema_delta_ref": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "mutation": {
      "type": "object",
      "required": ["history"],
      "properties": {
        "history": {
          "type": "array",
          "items": { "$ref": "#/$defs/mutation_entry" }
        }
      },
      "additionalProperties": false
    },
    "ssp_links": {
      "type": "object",
      "properties": {
        "concept_spec": { "type": "string" },
        "mvp_plan": { "type": "string" },
        "active_doc": { "type": "string" },
        "summon_eligible": { "type": "boolean", "default": true },
        "engineering_class": {
          "type": "string",
          "pattern": "^[A-Z][a-zA-Z0-9]*([A-Z][a-zA-Z0-9]*)+$",
          "description": "PascalCase DomainFunctionRole engineering identifier."
        },
        "mythic_label": {
          "type": "string",
          "minLength": 1,
          "description": "Short mythic name for operator docs and comments."
        },
        "linguistic_version": {
          "type": "string",
          "minLength": 1,
          "description": "Semver for linguistic layer; bump on MP-X mythic/engineering changes."
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "identity": { "properties": { "stage": { "const": "concept" } } } }
      },
      "then": {
        "properties": {
          "runtime": {
            "properties": {
              "surface": { "maxItems": 0 }
            }
          },
          "proof": {
            "properties": {
              "posture": { "const": "asserted" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "identity": { "properties": { "stage": { "const": "mvp" } } } }
      },
      "then": {
        "properties": {
          "proof": {
            "properties": {
              "posture": { "enum": ["mvp", "governed"] },
              "bundles": { "minItems": 1 }
            }
          },
          "runtime": {
            "properties": {
              "surface": { "minItems": 1 }
            }
          }
        }
      }
    }
  ]
}
