{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urg.local/schemas/fos.v1.json",
  "title": "Founder Operating System v0.1",
  "type": "object",
  "properties": {
    "memory_objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/MemoryObject" }
    },
    "blueprints": {
      "type": "array",
      "items": { "$ref": "#/$defs/Blueprint" }
    }
  },
  "$defs": {
    "ContinuityThread": {
      "type": "object",
      "required": ["thread_id", "event_ids"],
      "properties": {
        "thread_id": { "type": "string" },
        "parent_thread_id": { "type": ["string", "null"] },
        "event_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "ContinuityEvent": {
      "type": "object",
      "required": ["event_id", "thread_id", "type", "payload", "timestamp", "lineage"],
      "properties": {
        "event_id": { "type": "string" },
        "thread_id": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "string" },
        "lineage": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "LineagePointer": {
      "type": "object",
      "required": ["from_event_id", "to_event_id"],
      "properties": {
        "from_event_id": { "type": "string" },
        "to_event_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "EventType": {
      "type": "string",
      "enum": ["Concept", "Architecture", "Governance", "Decision", "Evidence"]
    },
    "MemoryType": {
      "type": "string",
      "enum": [
        "Concept",
        "Pattern",
        "Invariant",
        "Architecture",
        "GovernanceContract",
        "Decision",
        "Evidence",
        "ContinuityThread",
        "SystemModel",
        "Blueprint",
        "FieldDefinition"
      ]
    },
    "MemoryObject": {
      "type": "object",
      "required": ["id", "mtype", "definition", "evidence_refs", "lineage", "version", "continuity_thread"],
      "properties": {
        "id": { "type": "string" },
        "mtype": { "$ref": "#/$defs/MemoryType" },
        "definition": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "lineage": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "version": { "type": "string", "minLength": 1 },
        "continuity_thread": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "Blueprint": {
      "type": "object",
      "required": ["id", "source_ids", "kind", "content", "version", "continuity_thread"],
      "properties": {
        "id": { "type": "string" },
        "source_ids": { "type": "array", "items": { "type": "string" } },
        "kind": { "type": "string", "enum": ["Architecture", "Governance"] },
        "content": { "type": "object" },
        "version": { "type": "string" },
        "continuity_thread": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
