{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ul_lifted_model.v1",
  "title": "UL Lifted Model v1",
  "description": "Semantic lift of UBO machine code for AAIS registration and Forge compilation.",
  "type": "object",
  "required": [
    "version",
    "meta",
    "control",
    "data",
    "effects",
    "invariants",
    "capabilities",
    "runtime_shape"
  ],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "meta": {
      "type": "object",
      "required": ["program_id", "format", "os_family", "architecture", "entry_point", "provenance"],
      "properties": {
        "program_id": {
          "type": "string",
          "description": "Equals UBO.binary_id"
        },
        "format": { "enum": ["pe", "elf", "macho", "dex", "wasm"] },
        "os_family": {
          "enum": ["windows", "linux", "macos", "android", "wasm", "native"]
        },
        "architecture": { "type": "string" },
        "entry_point": { "type": "integer", "minimum": 0 },
        "image_base": { "type": "integer", "minimum": 0 },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "virtual_address", "virtual_size", "kind"],
            "properties": {
              "name": { "type": "string" },
              "virtual_address": { "type": "integer" },
              "virtual_size": { "type": "integer" },
              "raw_size": { "type": "integer" },
              "flags": { "type": "string" },
              "kind": {
                "enum": ["code", "data", "rodata", "bss", "unknown"]
              }
            }
          }
        },
        "provenance": {
          "type": "object",
          "required": ["artifact_hash"],
          "properties": {
            "artifact_hash": { "type": "string" },
            "build_id": { "type": ["string", "null"] },
            "source_path": { "type": ["string", "null"] },
            "lifted_at": { "type": "string" }
          }
        }
      }
    },
    "control": {
      "type": "object",
      "required": ["blocks", "edges", "functions"],
      "properties": {
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["block_id", "start_vaddr", "size"],
            "properties": {
              "block_id": { "type": "string" },
              "start_vaddr": { "type": "integer" },
              "size": { "type": "integer" },
              "terminator": {
                "enum": ["fallthrough", "branch", "call", "return", "syscall", "unknown"]
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_block", "to_block", "kind"],
            "properties": {
              "from_block": { "type": "string" },
              "to_block": { "type": "string" },
              "kind": { "enum": ["fallthrough", "jump", "call", "return"] }
            }
          }
        },
        "functions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["function_id", "entry_vaddr"],
            "properties": {
              "function_id": { "type": "string" },
              "entry_vaddr": { "type": "integer" },
              "blocks": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "data": {
      "type": "object",
      "required": ["regions"],
      "properties": {
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["region_id", "kind", "virtual_address", "size"],
            "properties": {
              "region_id": { "type": "string" },
              "kind": { "enum": ["global", "stack", "heap", "unknown"] },
              "virtual_address": { "type": "integer" },
              "size": { "type": "integer" },
              "segment_name": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "effects": {
      "type": "object",
      "required": ["syscalls", "imports"],
      "properties": {
        "syscalls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["effect_id", "syscall_number", "bucket", "confidence"],
            "properties": {
              "effect_id": { "type": "string" },
              "syscall_number": { "type": ["integer", "null"] },
              "syscall_name": { "type": ["string", "null"] },
              "bucket": {
                "enum": ["fs", "net", "timer", "proc", "mem", "device_io", "unknown"]
              },
              "confidence": { "enum": ["proven", "heuristic", "unknown"] },
              "site_vaddr": { "type": "integer" },
              "block_id": { "type": ["string", "null"] }
            }
          }
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module", "symbol"],
            "properties": {
              "module": { "type": "string" },
              "symbol": { "type": "string" },
              "slot_id": { "type": "string" }
            }
          }
        }
      }
    },
    "invariants": {
      "type": "object",
      "required": ["rules"],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["invariant_id", "kind", "severity"],
            "properties": {
              "invariant_id": { "type": "string" },
              "kind": {
                "enum": ["safety", "liveness", "protocol", "hazard"]
              },
              "severity": { "enum": ["info", "warn", "block"] },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "required": ["resources", "authorities"],
      "properties": {
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["usl_capability_id", "class"],
            "properties": {
              "usl_capability_id": { "type": "string" },
              "class": {
                "enum": ["fs", "net", "proc", "mem", "ui", "ipc", "time", "crypto"]
              },
              "scope": { "type": "string" }
            }
          }
        },
        "authorities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["authority_id", "level"],
            "properties": {
              "authority_id": { "type": "string" },
              "level": { "enum": ["none", "read", "write", "execute", "admin"] }
            }
          }
        },
        "ceiling_id": { "type": ["string", "null"] }
      }
    },
    "runtime_shape": {
      "type": "object",
      "required": ["process_model", "admission", "health"],
      "properties": {
        "process_model": { "enum": ["oneshot", "persistent", "unknown"] },
        "admission": { "enum": ["single", "multi", "unknown"] },
        "health": {
          "type": "object",
          "properties": {
            "probe": { "type": "string" },
            "interval_seconds": { "type": "integer" }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
