{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cab.v1",
  "title": "Continuity Architecture Blueprint v1",
  "description": "Intent, decision, assumption, evidence, receipt, founder knowledge, succession, and reconstruction objects for reconstructable governance lineage.",
  "oneOf": [
    { "$ref": "#/$defs/IntentRecord" },
    { "$ref": "#/$defs/DecisionRecord" },
    { "$ref": "#/$defs/AssumptionRecord" },
    { "$ref": "#/$defs/EvidenceChain" },
    { "$ref": "#/$defs/ContinuityReceipt" },
    { "$ref": "#/$defs/FounderKnowledgeSnapshot" },
    { "$ref": "#/$defs/SuccessionProtocol" },
    { "$ref": "#/$defs/ReconstructionPlan" }
  ],
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "Timestamp": { "type": "string", "minLength": 1 },
    "StewardRef": {
      "type": "object",
      "required": ["steward_id", "display_name"],
      "properties": {
        "steward_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "role": { "type": "string" }
      },
      "additionalProperties": false
    },
    "IntentRecord": {
      "type": "object",
      "required": [
        "intent_id",
        "authors",
        "articulated_at",
        "scope",
        "problem_statement",
        "desired_outcomes",
        "created_at"
      ],
      "properties": {
        "intent_id": { "type": "string", "minLength": 1 },
        "authors": { "$ref": "#/$defs/StringArray" },
        "articulated_at": { "$ref": "#/$defs/Timestamp" },
        "scope": { "type": "object" },
        "problem_statement": { "type": "string", "minLength": 1 },
        "desired_outcomes": { "$ref": "#/$defs/StringArray" },
        "constraints": { "$ref": "#/$defs/StringArray" },
        "prior_intent_refs": { "$ref": "#/$defs/StringArray" },
        "decision_refs": { "$ref": "#/$defs/StringArray" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "DecisionRecord": {
      "type": "object",
      "required": [
        "decision_id",
        "decision_makers",
        "chosen_option",
        "rationale",
        "intent_refs",
        "created_at"
      ],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "decision_makers": { "$ref": "#/$defs/StringArray" },
        "intent_refs": { "$ref": "#/$defs/StringArray", "minItems": 1 },
        "options_considered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["option_id", "label"],
            "properties": {
              "option_id": { "type": "string" },
              "label": { "type": "string" },
              "pros": { "$ref": "#/$defs/StringArray" },
              "cons": { "$ref": "#/$defs/StringArray" }
            },
            "additionalProperties": false
          }
        },
        "chosen_option": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "govern_policy_refs": { "$ref": "#/$defs/StringArray" },
        "evidence_chain_refs": { "$ref": "#/$defs/StringArray" },
        "assumption_refs": { "$ref": "#/$defs/StringArray" },
        "continuity_receipt_refs": { "$ref": "#/$defs/StringArray" },
        "review_conditions": { "type": "string" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "AssumptionRecord": {
      "type": "object",
      "required": ["assumption_id", "statement", "assumption_type", "confidence", "created_at"],
      "properties": {
        "assumption_id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 },
        "assumption_type": {
          "type": "string",
          "enum": ["technical", "social", "economic", "organizational", "environmental", "other"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "justification": { "type": "string" },
        "evidence_chain_refs": { "$ref": "#/$defs/StringArray" },
        "fragility_markers": { "$ref": "#/$defs/StringArray" },
        "review_cadence": { "type": "string" },
        "decision_refs": { "$ref": "#/$defs/StringArray" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "EvidenceChain": {
      "type": "object",
      "required": ["chain_id", "sources", "methods", "created_at"],
      "properties": {
        "chain_id": { "type": "string", "minLength": 1 },
        "neomundi_measurement_refs": { "$ref": "#/$defs/StringArray" },
        "sources": { "$ref": "#/$defs/StringArray" },
        "methods": { "$ref": "#/$defs/StringArray" },
        "integrity_assessment": { "type": "string" },
        "assumption_refs": { "$ref": "#/$defs/StringArray" },
        "decision_refs": { "$ref": "#/$defs/StringArray" },
        "continuity_receipt_refs": { "$ref": "#/$defs/StringArray" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "ContinuityReceipt": {
      "type": "object",
      "description": "CAB runtime receipt — links Nova continuity_governance to decision lineage.",
      "required": [
        "receipt_id",
        "identity_context",
        "authority_surface",
        "event_description",
        "trace_id",
        "created_at"
      ],
      "properties": {
        "receipt_id": { "type": "string", "minLength": 1 },
        "identity_context": { "type": "object" },
        "authority_surface": { "$ref": "#/$defs/StringArray" },
        "event_description": { "type": "string", "minLength": 1 },
        "evaluation_outcome": { "type": "string" },
        "trace_id": { "type": "string", "minLength": 1 },
        "trace_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "proof_id": { "type": "string" },
        "cvr_id": { "type": "string" },
        "cvr_snapshot": { "type": "object" },
        "decision_refs": { "$ref": "#/$defs/StringArray" },
        "govern_policy_refs": { "$ref": "#/$defs/StringArray" },
        "continuity_governance": { "type": "object" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "FounderKnowledgeSnapshot": {
      "type": "object",
      "required": ["snapshot_id", "knowledge_holder", "narrative", "created_at"],
      "properties": {
        "snapshot_id": { "type": "string", "minLength": 1 },
        "knowledge_holder": { "$ref": "#/$defs/StewardRef" },
        "narrative": { "type": "string", "minLength": 1 },
        "mental_models": { "$ref": "#/$defs/StringArray" },
        "failure_scars": { "$ref": "#/$defs/StringArray" },
        "artifact_pointers": { "$ref": "#/$defs/StringArray" },
        "intent_refs": { "$ref": "#/$defs/StringArray" },
        "decision_refs": { "$ref": "#/$defs/StringArray" },
        "succession_notes": { "type": "string" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "SuccessionProtocol": {
      "type": "object",
      "required": ["protocol_id", "roles", "onboarding_steps", "offboarding_steps", "created_at"],
      "properties": {
        "protocol_id": { "type": "string", "minLength": 1 },
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role_id", "title"],
            "properties": {
              "role_id": { "type": "string" },
              "title": { "type": "string" },
              "required_cab_objects": { "$ref": "#/$defs/StringArray" }
            },
            "additionalProperties": false
          }
        },
        "onboarding_steps": { "$ref": "#/$defs/StringArray" },
        "offboarding_steps": { "$ref": "#/$defs/StringArray" },
        "review_triggers": { "$ref": "#/$defs/StringArray" },
        "reconstruction_plan_refs": { "$ref": "#/$defs/StringArray" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    },
    "ReconstructionPlan": {
      "type": "object",
      "required": [
        "plan_id",
        "minimal_object_refs",
        "reconstruction_order",
        "runtime_component_map",
        "created_at"
      ],
      "properties": {
        "plan_id": { "type": "string", "minLength": 1 },
        "minimal_object_refs": { "$ref": "#/$defs/StringArray", "minItems": 1 },
        "reconstruction_order": { "$ref": "#/$defs/StringArray" },
        "runtime_component_map": { "type": "object" },
        "known_gaps": { "$ref": "#/$defs/StringArray" },
        "steward_recommendations": { "$ref": "#/$defs/StringArray" },
        "superseded_by": { "type": "string" },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      },
      "additionalProperties": false
    }
  }
}
