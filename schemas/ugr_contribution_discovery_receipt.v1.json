{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UGR Contribution Discovery Receipt v1.1",
  "type": "object",
  "required": [
    "receipt_schema_version",
    "receipt_id",
    "contribution_id",
    "contribution_type",
    "tenant_id",
    "operator_id",
    "receipt_sig"
  ],
  "properties": {
    "receipt_schema_version": { "type": "string" },
    "receipt_id": { "type": "string" },
    "contribution_id": { "type": "string", "minLength": 64, "maxLength": 64 },
    "contribution_type": {
      "type": "string",
      "enum": ["subsystem", "workflow", "organ", "proof", "invariant", "capability", "substrate"]
    },
    "payload": { "type": "object" },
    "tenant_id": { "type": "string" },
    "operator_id": { "type": "string" },
    "receipt_sig": { "type": "string" }
  }
}
