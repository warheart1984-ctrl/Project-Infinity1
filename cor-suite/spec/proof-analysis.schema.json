{
  "$id": "https://continuity-os.dev/schemas/cor-suite/proof-analysis/1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proof Analysis Result",
  "type": "object",
  "properties": {
    "analysisId": { "type": "string" },
    "corStateRef": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "dependencyMaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependencyMap" }
    },
    "regressions": {
      "type": "array",
      "items": { "$ref": "#/$defs/regression" }
    }
  },
  "required": ["analysisId", "corStateRef", "generatedAt", "claims"],
  "$defs": {
    "claim": {
      "type": "object",
      "properties": {
        "claimId": { "type": "string" },
        "type": { "type": "string" },
        "summary": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error", "critical"]
        },
        "derivation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedRequirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["claimId", "type", "summary", "severity", "derivation"]
    },
    "dependencyMap": {
      "type": "object",
      "properties": {
        "rootRequirementId": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["rootRequirementId", "dependencies"]
    },
    "regression": {
      "type": "object",
      "properties": {
        "regressionId": { "type": "string" },
        "kind": { "type": "string", "enum": ["implementation", "verification", "evidence"] },
        "requirementId": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["regressionId", "kind", "requirementId", "description"]
    }
  }
}
