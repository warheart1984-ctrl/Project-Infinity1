{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.job_assignment.v1",
  "type": "object",
  "required": ["job_id", "org_id", "assignee_principal_id", "assigned_by"],
  "properties": {
    "job_id": { "type": "string" },
    "org_id": { "type": "string" },
    "assignee_principal_id": { "type": "string" },
    "assigned_by": { "type": "string" },
    "assigned_at": { "type": "string" },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] }
  }
}
