{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.proof_attestation.v1",
  "title": "Proof Attestation",
  "type": "object",
  "required": ["attestation_version", "attestation_id", "job_id", "runner_id", "result_hash"],
  "properties": {
    "attestation_version": { "const": "platform.proof_attestation.v1" },
    "attestation_id": { "type": "string" },
    "job_id": { "type": "string" },
    "runner_id": { "type": "string" },
    "region": { "type": "string" },
    "result_hash": { "type": "string" },
    "manifest_ref": { "type": "string" },
    "signed_at": { "type": "string" },
    "signature": { "type": "string" },
    "signature_alg": { "enum": ["hmac-sha256", "ed25519"] },
    "public_key_ref": { "type": "string" },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] }
  }
}
