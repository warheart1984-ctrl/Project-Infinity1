{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.platform_role_binding.v1",
  "title": "Platform Role Binding v1",
  "type": "object",
  "required": ["binding_version", "principal_id", "org_id", "role", "granted_at"],
  "properties": {
    "binding_version": { "const": "platform.platform_role_binding.v1" },
    "principal_id": { "type": "string" },
    "org_id": { "type": "string" },
    "role": { "enum": ["owner", "admin", "operator", "read_only", "platform_admin"] },
    "granted_by": { "type": "string" },
    "granted_at": { "type": "string", "format": "date-time" }
  }
}
