{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.platform_replay_manifest.v1",
  "title": "Platform Cross-Machine Replay Manifest v1",
  "type": "object",
  "required": ["manifest_version", "operational_status", "commands", "artifact_hashes"],
  "properties": {
    "manifest_version": { "const": "platform.platform_replay_manifest.v1" },
    "operational_status": { "enum": ["inactive", "active"] },
    "primary_machine": { "type": "string" },
    "secondary_machine": { "type": "string" },
    "subsystem": {
      "enum": ["mechanic", "slingshot", "lab", "ai_factory", "forgekeeper", "platform"]
    },
    "commands": { "type": "array", "items": { "type": "string" } },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
