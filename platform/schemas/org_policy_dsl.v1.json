{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.org_policy_dsl.v1",
  "title": "Org Policy DSL",
  "type": "object",
  "required": ["policy_version", "org_id", "rules_source"],
  "properties": {
    "policy_version": { "const": "platform.org_policy_dsl.v1" },
    "org_id": { "type": "string" },
    "rules_source": {
      "type": "string",
      "description": "Line-oriented rules: allow|deny|require <target> when <condition>"
    },
    "compiled_hash": { "type": "string" }
  }
}
