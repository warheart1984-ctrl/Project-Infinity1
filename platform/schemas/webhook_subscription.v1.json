{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.webhook_subscription.v1",
  "title": "Webhook Subscription",
  "type": "object",
  "required": ["subscription_version", "subscription_id", "org_id", "url", "event_types"],
  "properties": {
    "subscription_version": { "const": "platform.webhook_subscription.v1" },
    "subscription_id": { "type": "string" },
    "org_id": { "type": "string" },
    "url": { "type": "string" },
    "event_types": {
      "type": "array",
      "items": { "enum": ["job.status", "proof.status", "mesh.event", "mesh.autopilot"] }
    },
    "enabled": { "type": "boolean" },
    "created_at": { "type": "string" }
  }
}
