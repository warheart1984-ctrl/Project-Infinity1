{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.platform_job.v1",
  "title": "Platform Job v1",
  "type": "object",
  "required": [
    "job_version",
    "job_id",
    "org_id",
    "correlation_id",
    "subsystem",
    "subsystem_job_id",
    "kind",
    "status",
    "claim_label",
    "created_at",
    "updated_at",
    "actor_principal_id"
  ],
  "properties": {
    "job_version": { "const": "platform.platform_job.v1" },
    "job_id": { "type": "string" },
    "org_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "parent_job_id": { "type": "string" },
    "related_job_ids": { "type": "array", "items": { "type": "string" } },
    "job_type": { "type": "string" },
    "priority": { "enum": ["low", "normal", "high"] },
    "cost_estimate": { "type": "number" },
    "actual_cost": { "type": "number" },
    "sla_class": { "enum": ["interactive", "batch", "proof"] },
    "tenant_id": { "type": "string" },
    "region": { "type": "string" },
    "proof_status": { "enum": ["asserted", "proven", "disputed"] },
    "primary_hash": { "type": "string" },
    "secondary_hash": { "type": "string" },
    "proof_consensus": { "type": "string" },
    "runtime_ms": { "type": "integer" },
    "tokens_used": { "type": "integer" },
    "subsystem": {
      "enum": ["mechanic", "forgekeeper", "slingshot", "lab", "ai_factory"]
    },
    "subsystem_job_id": { "type": "string" },
    "kind": { "type": "string" },
    "status": {
      "enum": [
        "queued",
        "running",
        "complete",
        "failed",
        "cancelled"
      ]
    },
    "claim_label": { "enum": ["asserted", "proven", "rejected"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "actor_principal_id": { "type": "string" },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["link_type", "target_id"],
        "properties": {
          "link_type": {
            "enum": [
              "mechanic_case",
              "slingshot_frame",
              "factory_build",
              "lab_session",
              "forgekeeper_plan"
            ]
          },
          "target_id": { "type": "string" },
          "uri": { "type": "string" }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
