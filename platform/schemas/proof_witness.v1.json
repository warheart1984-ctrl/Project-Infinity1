{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "platform.proof_witness.v1",
  "type": "object",
  "required": ["witness_id", "status"],
  "properties": {
    "witness_version": { "const": "platform.proof_witness.v1" },
    "witness_id": { "type": "string" },
    "region": { "type": "string" },
    "public_key_ref": { "type": "string" },
    "status": { "enum": ["active", "revoked"] }
  }
}
