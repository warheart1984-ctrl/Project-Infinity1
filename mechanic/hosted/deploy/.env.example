MECHANIC_REQUIRE_API_KEY=1
MECHANIC_HOSTED_API_KEY_SHA256=replace-with-sha256
MECHANIC_ARTIFACT_SIGNING_SECRET=replace-with-random-32-byte-secret
MECHANIC_GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
MECHANIC_GITHUB_APP_ID=
MECHANIC_GITHUB_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
MECHANIC_MAX_REQUEST_BYTES=1048576
MECHANIC_RATE_LIMIT_PER_MINUTE=120
MECHANIC_MAX_REPO_BYTES=25000000
MECHANIC_MAX_WORKERS=4
MECHANIC_CI_REPLAY_COMMAND=
MECHANIC_SECOND_MACHINE_REPLAY_COMMAND=
